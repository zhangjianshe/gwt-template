<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:buttons="urn:import:cn.mapway.ui.client.widget.buttons">
    <ui:style>
        .box {
            line-height: 150%;
            min-height: 50px;

        }

        .box:focus {
            outline: none;
            cursor: default;
        }

        .operator {
            position: absolute;
            top: 0;
            padding: 5px;
            left: 5px;
            width: 40px;
        }

        .block {
            position: relative;
            padding-left: 45px;
        }

        .btn {
            border-radius: 4px;
            width: 23px;
            height: 23px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .btn:HOVER {
            background-color: #f0f0f0;
        }
    </ui:style>
    <g:HTMLPanel ui:field="box" addStyleNames="{style.block}">
        <g:HTMLPanel ui:field="operator" visible="false" addStyleNames="{style.operator}">
            <buttons:PlusButton pushButton="true" addStyleNames="{style.btn}" ui:field="btnAdd"/>
        </g:HTMLPanel>
        <g:HTMLPanel ui:field="root" addStyleNames="{style.box}"/>
    </g:HTMLPanel>
</ui:UiBinder>