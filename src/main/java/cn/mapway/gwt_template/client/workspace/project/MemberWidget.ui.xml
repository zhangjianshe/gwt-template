<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'>
    <ui:style>
        .box {
            display: inline-grid;
            align-items: center;
            justify-items: center;
            justify-content: flex-start;
            grid-template-columns: auto auto;
        }

        .avatar {
            width: 20px;
            height: 20px;
            border-radius: 50%;

        }

        .name {
            font-size: 1rem;
            font-style: italic;
            color: #444;
            justify-self: flex-end;
        }</ui:style>
    <g:HTMLPanel addStyleNames="{style.box}">
        <g:Image ui:field="avatar" addStyleNames="{style.avatar}"/>
        <g:Label ui:field="lbName" addStyleNames="{style.name}"/>
    </g:HTMLPanel>
</ui:UiBinder>