<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'>
    <ui:style type="cn.mapway.gwt_template.client.workspace.issue.CommentItem.SStyle">
        /* 基础容器：去掉外边框，改为底部细线 */
        .item-container {
            display: flex;
            padding: 12px 0;
            border-bottom: 1px solid #f0f2f5;
            position: relative;
        }

        .avatar-area {
            width: 40px;
            flex-shrink: 0;
            text-align: center;
        }

        .avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background-color: #f0f0f0;
            border: 1px solid #eee;
        }

        .content-area {
            flex: 1;
            margin-left: 12px;
            min-width: 0; /* 防止溢出 */
        }

        .header {
            margin-bottom: 4px;
            display: flex;
            align-items: baseline;
        }

        .user-name {
            font-weight: 600;
            color: #1f2328;
            font-size: 14px;
        }

        .date {
            color: #656d76;
            font-size: 12px;
            margin-left: 8px;
        }

        .body {
            color: #333;
            font-size: 14px;
            line-height: 1.6;
            word-break: break-word;
        }

        .body img {
            max-width: 100%;
            height: auto;
            border-radius: 6px;
        }

        /* --- 系统日志样式：更紧凑、颜色更淡 --- */
        .system-log {
            padding: 4px 0 4px 52px; /* 对齐到内容区 */
            border-bottom: none;
            color: #656d76;
            font-size: 13px;
        }

        .system-log .body {
            color: #656d76;
            font-style: italic;
        }

        .system-icon {
            color: #888;
            margin-right: 8px;
        }
    </ui:style>

    <g:HTMLPanel ui:field="mainPanel" addStyleNames="{style.item-container}">
        <g:HTMLPanel ui:field="pnlAvatar" addStyleNames="{style.avatar-area}">
            <g:Image ui:field="imgAvatar" addStyleNames="{style.avatar}"/>
        </g:HTMLPanel>

        <g:HTMLPanel addStyleNames="{style.content-area}">
            <g:HTMLPanel ui:field="pnlHeader" addStyleNames="{style.header}">
                <g:Label ui:field="lbUser" addStyleNames="{style.user-name}"/>
                <g:Label ui:field="lbDate" addStyleNames="{style.date}"/>
            </g:HTMLPanel>

            <g:HTML ui:field="htmlContent" addStyleNames="{style.body}"/>
        </g:HTMLPanel>
    </g:HTMLPanel>
</ui:UiBinder>