<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:project="urn:import:cn.mapway.gwt_template.client.workspace.project"
             xmlns:gantt="urn:import:cn.mapway.gwt_template.client.workspace.gantt"
             xmlns:res="urn:import:cn.mapway.gwt_template.client.workspace.res"
             xmlns:repo="urn:import:cn.mapway.gwt_template.client.workspace.repo"
             xmlns:milestone="urn:import:cn.mapway.gwt_template.client.workspace.calendar"
             xmlns:issue="urn:import:cn.mapway.gwt_template.client.workspace.issue"
             xmlns:wiki="urn:import:cn.mapway.gwt_template.client.workspace.wiki">
    <ui:style>
        .toolbar {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 4px;
            padding: 0 8px;
        }</ui:style>
    <g:LayoutPanel ui:field="root">
        <g:layer>
            <g:TabLayoutPanel ui:field="mainTab" barHeight="50">
                <g:tab>
                    <g:header>📊 项目概况</g:header>
                    <g:LayoutPanel>
                        <g:layer top="15px" bottom="15px" left="15px" right="15px">
                            <project:ProjectCard ui:field="projectCard"/>
                        </g:layer>
                    </g:LayoutPanel>
                </g:tab>
                <g:tab>
                    <g:header>📅 任务甘特图</g:header>
                    <g:DockLayoutPanel>
                        <g:center>
                            <gantt:GanttWidget ui:field="gantt"/>
                        </g:center>
                    </g:DockLayoutPanel>
                </g:tab>
                <g:tab>
                    <g:header>🗓️ 项目日历</g:header>
                    <milestone:ProjectCalendarWidget ui:field="projectCalendar"/>
                </g:tab>
                <g:tab>
                    <g:header>🐞 项目问题</g:header>
                    <issue:ProjectIssueFrame ui:field="issuePanel"/>
                </g:tab>
                <g:tab>
                    <g:header>✍️ 项目WIKI</g:header>
                    <wiki:WikiFrame ui:field="wikiFrame"/>
                </g:tab>

                <g:tab>
                    <g:header>🗄️ 项目档案</g:header>
                    <res:ProjectResourcePanel ui:field="projectResource"/>
                </g:tab>
                <g:tab>
                    <g:header>📦 代码仓库</g:header>
                    <repo:ProjectRepoPanel ui:field="repoPanel"/>
                </g:tab>
                <g:tab>
                    <g:header>👥 项目人员</g:header>
                    <project:ProjectTeamMemberPanel ui:field="teamPanel"/>
                </g:tab>
            </g:TabLayoutPanel>
        </g:layer>
        <g:layer right="0" top="0" height="50" width="300px">
            <g:HTMLPanel ui:field="toolbar" addStyleNames="{style.toolbar}"/>
        </g:layer>
    </g:LayoutPanel>
</ui:UiBinder>
