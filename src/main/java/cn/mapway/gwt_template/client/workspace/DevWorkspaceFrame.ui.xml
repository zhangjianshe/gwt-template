<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget"
             xmlns:workspace="urn:import:cn.mapway.gwt_template.client.workspace">
    <ui:style>
        .top {
            display: flex;
            align-items: center;
            padding: 10px;
            justify-content: space-between;
        }
    </ui:style>
    <g:DockLayoutPanel>
        <g:west size="400">
            <g:DockLayoutPanel addStyleNames="ai-border-right">
                <g:north size="50">
                    <g:HTMLPanel addStyleNames="{style.top} ai-border-bottom">
                        <widget:Header>工作空间</widget:Header>
                        <g:Anchor ui:field="btnCreateWorkspace">创建</g:Anchor>
                    </g:HTMLPanel>
                </g:north>
                <g:center>
                    <g:ScrollPanel>
                        <workspace:DevWorkspaceTree ui:field="workspaceList"/>
                    </g:ScrollPanel>
                </g:center>
            </g:DockLayoutPanel>
        </g:west>
        <g:center>
            <workspace:WorkspaceDetailPanel ui:field="detailPanel"/>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>