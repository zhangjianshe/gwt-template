<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
>
    <ui:style>
        .top {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 4px;
            border-bottom: solid 1px #e0e0e0;
            padding: 0 10px;
        }
    </ui:style>
    <g:DockLayoutPanel ui:field="root">
        <g:north size="50">
            <g:HTMLPanel addStyleNames="{style.top}">
                <g:HorizontalPanel ui:field="navi" verticalAlignment="middle" spacing="4">

                </g:HorizontalPanel>
            </g:HTMLPanel>
        </g:north>
    </g:DockLayoutPanel>
</ui:UiBinder>