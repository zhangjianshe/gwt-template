<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'>
    <ui:style>
        .box {
            display: flex;
            align-items: center;
            justify-content: center;
            flex-flow: column;
        }

        .header {
            font-weight: bold;
            font-size: 1.2rem;
        }

        .msg {
            margin: 20px;
            line-height: 200%;
            max-height: 400px;
        }

    </ui:style>
    <g:DockLayoutPanel ui:field="root">
        <g:center>
            <g:ScrollPanel>
                <g:HTMLPanel>
                    <g:HTMLPanel addStyleNames="{style.box}">
                        <g:Label ui:field="header" addStyleNames="{style.header}"/>
                        <g:Label ui:field="msg" addStyleNames="{style.msg}"/>
                    </g:HTMLPanel>
                </g:HTMLPanel>
            </g:ScrollPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>