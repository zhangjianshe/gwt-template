<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        .ws-card {
            width: 260px;
            height: 180px;
            background: white;
            border: 1px solid #eef0f2;
            border-radius: 12px;
            padding: 20px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            display: flex;
            flex-direction: column;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
        }

        .ws-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
            border-color: #1890ff;
        }

        .ws-icon {
            font-size: 32px;
            margin-bottom: 15px;
        }

        .ws-title {
            font-size: 18px;
            font-weight: 600;
            color: #333;
            margin-bottom: 8px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .ws-info {
            font-size: 13px;
            color: #8c8c8c;
            flex-grow: 1;
        }

        .ws-footer {
            font-size: 12px;
            color: #bfbfbf;
            border-top: 1px solid #f0f0f0;
            padding-top: 10px;
        }
    </ui:style>
    <g:HTMLPanel ui:field="container" addStyleNames="{style.ws-card}">
        <div class="{style.ws-icon}">
            <widget:FontIcon ui:field="icon"/>
        </div>
        <g:Label ui:field="lbName" addStyleNames="{style.ws-title}"/>
        <g:Label ui:field="lbSummary" addStyleNames="{style.ws-info}"/>
        <div class="{style.ws-footer}">
            <g:Label ui:field="lbTime"/>
            <g:Label ui:field="lbStatus"/>
        </div>
    </g:HTMLPanel>
</ui:UiBinder>