<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'>
    <ui:style>
        .box {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 4px;
        }

        .box[enabled="true"] {
            cursor: pointer;
        }

        .img {
            width: 24px;
            height: 24px;
            border-radius: 50%;
        }</ui:style>
    <g:HTMLPanel ui:field="root" addStyleNames="{style.box}">
        <g:Image ui:field="imageSource" addStyleNames="{style.img}"/>
        <g:Image ui:field="imageArrow" width="32px" height="22px"/>
        <g:Image ui:field="imageTarget" addStyleNames="{style.img}"/>
    </g:HTMLPanel>
</ui:UiBinder>