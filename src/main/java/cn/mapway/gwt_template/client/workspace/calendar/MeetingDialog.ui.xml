<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:dialog="urn:import:cn.mapway.ui.client.widget.dialog"
             xmlns:calendar="urn:import:cn.mapway.gwt_template.client.workspace.calendar">
    <g:DockLayoutPanel ui:field="root">
        <g:south size="60">
            <dialog:SaveBar ui:field="saveBar"/>
        </g:south>
        <g:center>
            <calendar:MeetingPanel ui:field="panel"/>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>