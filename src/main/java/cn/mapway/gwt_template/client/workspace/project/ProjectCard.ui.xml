<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:buttons="urn:import:cn.mapway.ui.client.widget.buttons">
    <ui:style>
        .card {
            background: white;
            border: 1px solid #e0e0e0;
            width: 70%;
            min-width: 70%;
            min-height: 100%;
            position: relative;
        }

        .info_main {
            padding: 20px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .title_row {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 8px;
            flex-flow: column;
            margin-top: 50px;
        }

        .title {
            font-size: 1.8rem;
            font-weight: bold;
            color: #2c3e50;
        }

        .desc {
            background-color: #f0f0f0;
            padding: 30px;
            line-height: 200%;
            color: #888;
            font-size: 0.8rem;
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
        }

        .stats_row {
            display: flex;
            gap: 25px;
            padding: 30px;
            background-color: #f0f0f0;
        }

        .stat_item {
            display: flex;
            flex-direction: column;
            font-size: 12px;
            color: #95a5a6;
        }

        .stat_value {
            font-size: 15px;
            font-weight: bold;
            color: #34495e;
            margin-top: 4px;
        }


        .security {
            position: relative;
            padding: 0;
            border: double 2px #444;
            width: 250px;
            height: 100px;
            margin-bottom: 20px;
        }

        .sec_text {
            font-weight: bold;
            font-size: 2.3rem;
            display: flex;
            align-items: center;
            justify-content: center;
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 40px;
        }

        .sec_tip {
            position: absolute;
            left: 0;
            right: 0;
            bottom: 0;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 1.1rem;
            background-color: #444;
            color: white;
        }

        .date {
            font-size: 1.1rem;
            padding: 30px 30px;
        }

        .btn {
            margin-top: 8px;
            padding: 4px;
        }

    </ui:style>

    <g:HTMLPanel styleName="{style.card}">
        <g:HTMLPanel styleName="{style.info_main}">
            <g:HTMLPanel addStyleNames="{style.security}">
                <g:Label ui:field="lbSecurity" addStyleNames="{style.sec_text}"/>
                <g:Label addStyleNames="{style.sec_tip}">秘密等级</g:Label>
            </g:HTMLPanel>
            <g:VerticalPanel horizontalAlignment="right">
                <g:HTMLPanel styleName="{style.stats_row}">
                    <div class="{style.stat_item}">
                        <span>创建者</span>
                        <span class="{style.stat_value}" ui:field="lbCreator">--</span>
                    </div>
                    <div class="{style.stat_item}">
                        <span>团队成员</span>
                        <span class="{style.stat_value}" ui:field="lbMemberCount">0</span>
                    </div>
                    <div class="{style.stat_item}">
                        <span>当前进度</span>
                        <span class="{style.stat_value}" ui:field="lbProgress">0%</span>
                    </div>
                </g:HTMLPanel>
                <g:HorizontalPanel ui:field="tools">
                    <buttons:AiButton ui:field="btnEdit">编辑项目信息</buttons:AiButton>
                </g:HorizontalPanel>
            </g:VerticalPanel>
        </g:HTMLPanel>
        <div class="{style.title_row}">
            <g:HTMLPanel styleName="{style.title}" ui:field="pnlName"/>
            <g:InlineLabel ui:field="lbCreateTime" styleName="{style.date}"/>
        </div>
        <g:HTMLPanel styleName="{style.desc}" ui:field="pnlSummary"/>
    </g:HTMLPanel>
</ui:UiBinder>