<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'>
    <ui:style>
        .card {
            background: white;
            padding: 24px;
            display: flex;
            align-items: flex-start; /* 顶部对齐 */
            border: 1px solid #f0f0f0;
            margin: 15px;
            position: relative;
        }

        /* 左侧色条修饰 */
        .color_bar {
        }

        .icon_box {
            width: 64px;
            height: 64px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 20px;
            font-size: 28px;
            color: white;
            flex-shrink: 0;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        }

        .info_main {
            flex: 1;
        }

        .title_row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .title {
            font-size: 20px;
            font-weight: 600;
            color: #2c3e50;
        }

        .desc {
            font-size: 14px;
            color: #7f8c8d;
            line-height: 1.5;
            margin-bottom: 16px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .stats_row {
            display: flex;
            gap: 25px;
            padding-top: 15px;
            border-top: 1px dashed #eee;
        }

        .stat_item {
            display: flex;
            flex-direction: column;
            font-size: 12px;
            color: #95a5a6;
        }

        .stat_value {
            font-size: 15px;
            font-weight: bold;
            color: #34495e;
            margin-top: 4px;
        }

        .progress_container {
            width: 150px;
            margin-left: 30px;
            align-self: center;
        }
    </ui:style>

    <g:HTMLPanel styleName="{style.card}">
        <g:HTMLPanel styleName="{style.color_bar}" ui:field="pnlColorBar"/>

        <g:HTMLPanel styleName="{style.icon_box}" ui:field="pnlIconBox">
            <i ui:field="iconElement"/>
        </g:HTMLPanel>

        <g:HTMLPanel styleName="{style.info_main}">
            <div class="{style.title_row}">
                <g:HTMLPanel styleName="{style.title}" ui:field="pnlName"/>
                <g:InlineLabel ui:field="lbCreateTime" styleName="small-date"/>
            </div>

            <g:HTMLPanel styleName="{style.desc}" ui:field="pnlSummary"/>

            <div class="{style.stats_row}">
                <div class="{style.stat_item}">
                    <span>创建者</span>
                    <span class="{style.stat_value}" ui:field="lbCreator">--</span>
                </div>
                <div class="{style.stat_item}">
                    <span>团队成员</span>
                    <span class="{style.stat_value}" ui:field="lbMemberCount">0</span>
                </div>
                <div class="{style.stat_item}">
                    <span>当前进度</span>
                    <span class="{style.stat_value}" ui:field="lbProgress">0%</span>
                </div>
            </div>
        </g:HTMLPanel>

        <g:HTMLPanel styleName="{style.progress_container}" ui:field="pnlExtra">
        </g:HTMLPanel>
    </g:HTMLPanel>
</ui:UiBinder>