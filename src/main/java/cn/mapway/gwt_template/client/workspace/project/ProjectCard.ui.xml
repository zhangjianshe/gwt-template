<?xml version="1.0" encoding="UTF-8"?>
<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'>
    <ui:style>

        .card {
            background-color: #f7f7f7;
            width: 100%;
            box-sizing: border-box;

            /* 1. 加上微弱的浅灰色边框 */
            border-bottom: 1px solid #e2e8f0;

            /* 2. 加上极其细腻的高级悬浮阴影，赋予它立体感，使其与下方列表剥离 */
            box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.05), 0 2px 8px -1px rgba(0, 0, 0, 0.03);

            /* 3. 加上圆角，使其具备“看板封装感” */
            border-radius: 12px 12px 0 0;

            /* 4. 拉大与下方列表项的物理距离 */
            margin-bottom: 32px;

            padding: 32px 40px 16px 40px;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        /* ========== 1. 主标题 ========== */
        .title {
            font-size: 2.4rem;
            font-weight: 750;
            line-height: 1.25;
            color: #191919;
            letter-spacing: -0.022em;
            margin-bottom: 8px;
            word-break: break-word;
        }

        /* ========== 2. 副标题 / 项目简介 ========== */
        .desc {
            font-size: 1.25rem;
            line-height: 1.5;
            color: #6b6b6b;
            font-weight: 400;
            margin-bottom: 28px;
            word-break: break-word;
        }

        /* ========== 3. 核心合并行 (包含人员信息与统计数据) ========== */
        .unified_meta_bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            width: 100%; /* 确保它横向100%撑满，右侧直接触及父级 40px padding 的边界 */
            padding: 16px 0 0 0;
            border-top: 1px solid #e2e8f0;
            margin-top: 12px;
        }

        /* 左侧：人员与时间组 */
        .left_user_group {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .avatar_placeholder {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background-color: #f2f2f2;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: #6b6b6b;
            border: 1px solid #e6e6e6;
        }

        .meta_text_group {
            display: flex;
            align-items: center; /* 内部信息同样横向单行排列 */
            gap: 10px;
        }

        .creator_name {
            font-size: 0.95rem;
            color: #191919;
            font-weight: 500;
        }

        .create_date {
            font-size: 0.875rem;
            color: #6b6b6b;
        }

        .security_badge {
            background-color: #f2f2f2;
            color: #6b6b6b;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 500;
            border: 1px solid #e6e6e6;
        }

        /* 右侧：统计数据组 */
        .right_stats_group {
            display: flex;
            align-items: center;
            gap: 28px; /* 统计项之间的间距 */
        }

        .stat_item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.875rem;
            color: #6b6b6b;
        }

        .stat_label {
            color: #8c8c8c;
        }

        .stat_value {
            font-weight: 600;
            color: #191919;
        }

    </ui:style>

    <g:HTMLPanel styleName="{style.card}" ui:field="card">

        <!-- 1. 主标题 -->
        <g:HTMLPanel styleName="{style.title}" ui:field="pnlName" />

        <!-- 2. 副标题 / 项目概述 -->
        <g:HTMLPanel styleName="{style.desc}" ui:field="pnlSummary" />

        <!-- 3. 统一的高级单行元数据与数据栏 -->
        <div class="{style.unified_meta_bar}">

            <!-- 左侧：人员档案与创建细节 -->
            <div class="{style.left_user_group}">
                <div class="{style.avatar_placeholder}">👤</div>
                <div class="{style.meta_text_group}">
                    <g:Label ui:field="lbCreator" addStyleNames="{style.creator_name}" />
                    <g:InlineLabel ui:field="lbCreateTime" styleName="{style.create_date}" />
                    <g:Label ui:field="lbSecurity" addStyleNames="{style.security_badge}" />
                </div>
            </div>

            <!-- 右侧：无缝集成的统计指标 -->
            <div class="{style.right_stats_group}">
                <div class="{style.stat_item}">
                    <span class="{style.stat_label}">团队成员</span>
                    <span class="{style.stat_value}" ui:field="lbMemberCount">0</span>
                </div>
                <div class="{style.stat_item}">
                    <span class="{style.stat_label}">当前进度</span>
                    <span class="{style.stat_value}" ui:field="lbProgress">0%</span>
                </div>
            </div>

        </div>

    </g:HTMLPanel>
</ui:UiBinder>