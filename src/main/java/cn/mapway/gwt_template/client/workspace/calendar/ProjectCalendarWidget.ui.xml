<?xml version="1.0" encoding="UTF-8"?>
<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g="urn:import:com.google.gwt.user.client.ui"
             xmlns:project="urn:import:cn.mapway.gwt_template.client.workspace.project"
             xmlns:buttons="urn:import:cn.mapway.ui.client.widget.buttons">
    <ui:style>
        /* 页面底座：提供外围大卡片所需的舒适边距 */
        .workspace {
            padding: 24px 40px;
            box-sizing: border-box;
            background-color: #ffffff;
        }

        /* ========== 统一的、带外框的全局主卡片容器 ========== */
        .main_timeline_card {
            background-color: #ffffff;
            width: 100%;
            box-sizing: border-box;

            /* 由大包裹容器统一托底，锁死所有子组件的边界 */
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            box-shadow: 0 4px 24px -2px rgba(0, 0, 0, 0.05);

            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        /* 隐藏由框架统一托管并搬移的临时工具容器 */
        .hidden_tools {
            display: none;
        }

        /* 统一列表包装层，确保列表信息流干净透彻 */
        .list_wrapper {
            width: 100%;
            background-color: #ffffff;
        }
    </ui:style>

    <g:ScrollPanel ui:field="root">
        <g:HTMLPanel addStyleNames="{style.workspace}">

            <g:HTMLPanel addStyleNames="{style.hidden_tools}">
                <g:HorizontalPanel ui:field="tools" spacing="4">
                    <buttons:AiButton ui:field="btnEdit" type="success">编辑项目</buttons:AiButton>
                    <buttons:AiButton ui:field="btnCreate" type="warning">创建大事记</buttons:AiButton>
                </g:HorizontalPanel>
            </g:HTMLPanel>

            <div class="{style.main_timeline_card}">
                <project:ProjectCard ui:field="projectCard"/>
                <g:HTMLPanel ui:field="eventList" addStyleNames="{style.list_wrapper}">
                </g:HTMLPanel>
            </div>

        </g:HTMLPanel>
    </g:ScrollPanel>
</ui:UiBinder>