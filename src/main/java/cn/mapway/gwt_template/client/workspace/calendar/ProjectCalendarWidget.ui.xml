<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:milestone="urn:import:cn.mapway.gwt_template.client.workspace.calendar"
             xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <widget:MySplitLayoutPanel ui:field="root" splitterSize="2">
        <widget:east size="600">
            <milestone:MeetingPanel ui:field="meetingPanel"/>
        </widget:east>
        <widget:center>
            <milestone:ProjectCalendar ui:field="calendar" width="100%" height="100%"/>
        </widget:center>
    </widget:MySplitLayoutPanel>
</ui:UiBinder>