<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:ace="urn:import:cn.mapway.ace.client">
    <g:DockLayoutPanel ui:field="root">
        <g:north size="0">
            <g:HorizontalPanel ui:field="tools" spacing="4">
                <g:Button ui:field="btnView">预览</g:Button>
                <g:Button ui:field="btnSave">保存</g:Button>
            </g:HorizontalPanel>
        </g:north>
        <g:center>
            <g:LayoutPanel ui:field="contentPanel">
                <g:layer>
                    <ace:AceEditor width="100%" height="100%" ui:field="editor"/>
                </g:layer>
                <g:layer>
                    <g:ScrollPanel ui:field="htmlPanel">
                        <g:HTML ui:field="html" addStyleNames="ai-panel-content markdown-body"/>
                    </g:ScrollPanel>
                </g:layer>
            </g:LayoutPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>