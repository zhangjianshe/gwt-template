<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:widget="urn:import:cn.mapway.gwt_template.client.workspace.widget"
             xmlns:ace="urn:import:cn.mapway.ace.client" xmlns:dialog="urn:import:cn.mapway.ui.client.widget.dialog"
             xmlns:task="urn:import:cn.mapway.gwt_template.client.workspace.task">

    <ui:import field="cn.mapway.gwt_template.client.workspace.team.BaseNode.*"/>

    <ui:style>
        .page {
            background-color: white;
            font-family: "mapway-font", sans-serif;
        }

        .header-box {
            padding: 24px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .title {
            font-size: 1.6rem;
            font-weight: bold;
            color: #222;
            padding: 2px 4px;
        }

        .title:focus {
            outline: 2px solid #66bfff; /* 使用 Raylib SKYBLUE */
            background-color: #fff;
            border-radius: 4px;
        }

        .title:hover {
            background-color: #f5f5f5; /* 使用 Raylib RAYWHITE */
            cursor: text;
        }

        .time-label {
            color: #666; /* 或者使用 COLOR_GRAY */
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            padding: 2px 4px;
        }

        .meta-item {
            display: grid;
            grid-template-columns: 30px 1fr;
            gap: 10px;
            font-size: 0.9rem;
            color: #555;
            align-items: center;
            padding: 2px 4px;
        }

        .icon {
            margin-right: 8px;
            color: #888;
        }

        .edit {
            padding: 2px 4px;
            width: 100%;
            line-height: 28px;
        }

        .edit:focus {
            outline: 2px solid #66bfff; /* 使用 Raylib SKYBLUE */
            background-color: #fff;
            border-radius: 4px;
        }
    </ui:style>

    <g:DockLayoutPanel ui:field="root" addStyleNames="{style.page}">
        <g:north size="200">
            <g:HTMLPanel addStyleNames="{style.header-box}">
                <widget:EditableLabel ui:field="lbName" addStyleNames="{style.title}"
                                      title="点击直接修改标题"/>
                <g:HorizontalPanel>
                    <g:DateLabel ui:field="lbTime"
                                 customFormat="yyyy年MM月dd日 HH:mm"
                                 addStyleNames="{style.time-label}"/>
                    <g:Label ui:field="lbDuration" addStyleNames="{style.time-label}"/>
                </g:HorizontalPanel>
                <g:Label/>
                <g:HTMLPanel addStyleNames="{style.meta-item}">
                    <g:Label text="📍 " addStyleNames="{style.icon}"/>
                    <widget:EditableLabel ui:field="lbLocation" addStyleNames="{style.edit}"/>
                </g:HTMLPanel>
                <g:HTMLPanel addStyleNames="{style.meta-item}">
                    <g:Label text="👥 " addStyleNames="{style.icon}"/>
                    <widget:EditableLabel ui:field="lbParticipate" addStyleNames="{style.edit}"/>
                </g:HTMLPanel>
            </g:HTMLPanel>
        </g:north>
        <g:south size="0">
            <g:Button ui:field="btnSave">保存</g:Button>
        </g:south>
        <g:center>
            <g:LayoutPanel addStyleNames="ai-border-top">
                <g:layer>
                    <g:TabLayoutPanel ui:field="tabs" barHeight="50">
                        <g:tab>
                            <g:header>会议纪要</g:header>
                            <ace:AceEditor ui:field="editor"/>
                        </g:tab>
                        <g:tab>
                            <g:header>会议附件</g:header>
                            <task:TaskAttachmentsPanel ui:field="attachmentPanel"/>
                        </g:tab>
                    </g:TabLayoutPanel>
                </g:layer>
                <g:layer right="0" top="0" height="50" width="120">
                    <g:HorizontalPanel height="50px" horizontalAlignment="right" ui:field="toolsPanel"
                                       verticalAlignment="middle">

                    </g:HorizontalPanel>
                </g:layer>
            </g:LayoutPanel>

        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>