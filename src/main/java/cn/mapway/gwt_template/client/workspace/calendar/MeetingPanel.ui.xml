<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:widget="urn:import:cn.mapway.gwt_template.client.workspace.widget"
             xmlns:ace="urn:import:cn.mapway.ace.client"
             xmlns:task="urn:import:cn.mapway.gwt_template.client.workspace.task"
             xmlns:buttons="urn:import:cn.mapway.ui.client.widget.buttons"
             xmlns:issue="urn:import:cn.mapway.gwt_template.client.workspace.issue"
>

    <ui:import field="cn.mapway.gwt_template.client.workspace.team.BaseNode.*"/>

    <ui:style>
        .page {
            background-color: white;
            font-family: "mapway-font", sans-serif;
        }

        .header-box {
            padding: 24px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .title {
            font-size: 1.6rem;
            font-weight: bold;
            color: #222;
            padding: 2px 4px;
        }

        .title:focus {
            outline: 2px solid #66bfff; /* 使用 Raylib SKYBLUE */
            background-color: #fff;
            border-radius: 4px;
        }

        .title:hover {
            background-color: #f5f5f5; /* 使用 Raylib RAYWHITE */
            cursor: text;
        }

        .time-label {
            color: #666; /* 或者使用 COLOR_GRAY */
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            padding: 2px 4px;
        }

        .meta-item {
            display: grid;
            grid-template-columns: 30px 1fr;
            gap: 10px;
            font-size: 0.9rem;
            color: #555;
            align-items: center;
            padding: 2px 4px;
        }

        .icon {
            margin-right: 8px;
            color: #888;
        }

        .edit {
            padding: 2px 4px;
            width: 100%;
            line-height: 28px;
        }

        .edit:focus {
            outline: 2px solid #66bfff; /* 使用 Raylib SKYBLUE */
            background-color: #fff;
            border-radius: 4px;
        }

        .content {
            padding: 10px;
        }

        .tools {
            display: flex;
            gap: 4px;
            align-items: center;
            justify-content: flex-end;
        }

        .preview {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .bigtip {
            font-weight: bold;
            font-size: 1.6rem;
            color: #d0d0d0;
        }</ui:style>

    <g:LayoutPanel ui:field="allLayers">
        <g:layer>
            <g:DockLayoutPanel ui:field="root" visible="false" addStyleNames="{style.page}">
                <g:north size="200">
                    <g:HTMLPanel addStyleNames="{style.header-box}">
                        <widget:EditableLabel ui:field="lbName" addStyleNames="{style.title}"
                                              title="点击直接修改标题"/>
                        <g:HorizontalPanel>
                            <g:DateLabel ui:field="lbTime"
                                         customFormat="yyyy年MM月dd日 HH:mm"
                                         addStyleNames="{style.time-label}"/>
                            <g:Label ui:field="lbDuration" addStyleNames="{style.time-label}"/>
                            <widget:TaskPriorityDropdown ui:field="ddlPriority"/>
                        </g:HorizontalPanel>
                        <g:Label/>
                        <g:HTMLPanel addStyleNames="{style.meta-item}">
                            <g:Label text="🚩 " addStyleNames="{style.icon}"/>
                            <widget:EditableLabel ui:field="lbLocation" addStyleNames="{style.edit}"/>
                        </g:HTMLPanel>
                        <g:HTMLPanel addStyleNames="{style.meta-item}">
                            <g:Label text="👥 " addStyleNames="{style.icon}"/>
                            <widget:EditableLabel ui:field="lbParticipate" addStyleNames="{style.edit}"/>
                        </g:HTMLPanel>
                    </g:HTMLPanel>
                </g:north>
                <g:south size="0">
                    <g:HorizontalPanel ui:field="editTools">
                        <buttons:AiButton ui:field="btnSave" type="warning" addStyleNames="ai-small">保存</buttons:AiButton>
                    </g:HorizontalPanel>
                </g:south>
                <g:center>
                    <g:LayoutPanel addStyleNames="ai-border-top">
                        <g:layer>
                            <g:TabLayoutPanel ui:field="tabs" barHeight="50">
                                <g:tab>
                                    <g:header>会议纪要</g:header>
                                    <widget:MarkdownBox ui:field="markdownBox"/>
                                </g:tab>
                                <g:tab>
                                    <g:header>会议附件</g:header>
                                    <task:TaskAttachmentsPanel ui:field="attachmentPanel"/>
                                </g:tab>
                            </g:TabLayoutPanel>
                        </g:layer>
                        <g:layer right="0" top="0" height="50" width="180">
                            <g:HTMLPanel height="50px" ui:field="toolsPanel"
                                         addStyleNames="{style.tools}">

                            </g:HTMLPanel>
                        </g:layer>
                    </g:LayoutPanel>

                </g:center>
            </g:DockLayoutPanel>
        </g:layer>
        <g:layer>
            <g:HTMLPanel addStyleNames="{style.preview}" ui:field="masker">
                <g:Label addStyleNames="{style.bigtip}">会议预览</g:Label>
            </g:HTMLPanel>
        </g:layer>
    </g:LayoutPanel>
</ui:UiBinder>