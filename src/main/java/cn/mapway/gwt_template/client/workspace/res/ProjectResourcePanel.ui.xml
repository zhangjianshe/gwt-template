<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:res="urn:import:cn.mapway.gwt_template.client.workspace.res"
             xmlns:view="urn:import:cn.mapway.gwt_template.client.workspace.view">
    <ui:style>
        .top {
            display: flex;
            align-items: center;
            padding: 0 4px;
            border-bottom: solid 1px #e0e0e0;
        }
    </ui:style>
    <g:DockLayoutPanel ui:field="root">
        <g:north size="40">
            <g:HTMLPanel addStyleNames="{style.top}" ui:field="naviBar"/>
        </g:north>
        <g:west size="400">
            <res:ProjectResourceList ui:field="list" addStyleNames="ai-border-right"/>
        </g:west>
        <g:center>
            <view:FilePreview ui:field="filePreview"/>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>