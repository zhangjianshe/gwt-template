<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:widget="urn:import:cn.mapway.gwt_template.client.workspace.widget">
    <ui:style>
        .box {
            height: 140px;
            padding-left: 45px;
        }

        .top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 18px;
            flex-flow: column;
        }

        .header {
            font-size: 28px;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .header:focus {
            outline: none !important;
        }

        .header img {
            width: 40px;
            height: 40px;

        }


        .avatar {
            width: 26px;
            height: 26px;
            border-radius: 50%;;
        }

        .flex {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 10px;
        }
    </ui:style>
    <g:HTMLPanel addStyleNames="{style.box}">
        <g:HTMLPanel ui:field="header" addStyleNames="{style.top}">
            <widget:EditableLabel ui:field="txtHeader" addStyleNames="{style.header}"/>
            <g:HTMLPanel addStyleNames="{style.flex}">
                <g:Image ui:field="lbAvatar" addStyleNames="{style.avatar}"/>
                <g:Label ui:field="lbUserName"/>
                <g:Label ui:field="lbModify"/>
                <g:Label ui:field="lbVersion"/>
            </g:HTMLPanel>
        </g:HTMLPanel>
    </g:HTMLPanel>
</ui:UiBinder>