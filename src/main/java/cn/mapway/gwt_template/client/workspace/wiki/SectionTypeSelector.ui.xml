<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:dialog="urn:import:cn.mapway.ui.client.widget.dialog">
    <ui:style>
        .box {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 10px;
            padding: 15px;
        }
    </ui:style>
    <g:DockLayoutPanel>
        <g:south size="60">
            <dialog:SaveBar ui:field="saveBar" showSave="false" saveText="选择"/>
        </g:south>
        <g:center>
            <g:ScrollPanel ui:field="scroller">
                <g:HTMLPanel ui:field="content" addStyleNames="{style.box}">

                </g:HTMLPanel>
            </g:ScrollPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>