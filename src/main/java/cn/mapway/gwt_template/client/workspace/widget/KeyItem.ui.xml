<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'>
    <ui:style>
        .box {
            display: flex;
            align-items: center;
            justify-content: space-between;
            line-height: 30px;
            padding: 0 4px;
        }

        .key {
            border: solid 1px #ccc;
            background-color: #f9f9f9;
            color: #333;
            font-weight: bold;
            padding: 2px 12px;
            border-radius: 4px;
            box-shadow: 0 2px 0 #ddd; /* 模拟按键厚度 */
            font-family: monospace;
            min-width: 20px;
            text-align: center;
        }
        .desc {
            color: #444;
        }</ui:style>
    <g:HTMLPanel addStyleNames="{style.box}">
        <g:Label ui:field="lbKey" addStyleNames="{style.key}"/>
        <g:Label ui:field="lbDesc" addStyleNames="{style.desc}"/>
    </g:HTMLPanel>
</ui:UiBinder>