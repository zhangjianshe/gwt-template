<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'>
    <ui:style>
        .box {
            display: flex;
            align-items: center;
            justify-content: flex-start; /* 改为靠左对齐 */
            gap: 1rem;
        }

        /* 鼠标悬停时稍微高亮，增加交互感 */
        .box:hover {
            background-color: #f5f5f5;
            border-radius: 4px;
        }


        .desc {
            color: #666;
            font-size: 14px;
            white-space: nowrap; /* 避免换行 */
        }

        .container {
            width: 130px;
            display: flex;
            align-items: center;
            justify-content: flex-start;
        }
    </ui:style>
    <g:HTMLPanel addStyleNames="{style.box}">
        <div class="{style.container}">
            <g:Label ui:field="lbKey" styleName="ai-code"/>
        </div>
        <g:Label ui:field="lbDesc" addStyleNames="{style.desc}"/>
    </g:HTMLPanel>
</ui:UiBinder>