<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:dialog="urn:import:cn.mapway.ui.client.widget.dialog"
             xmlns:widget1="urn:import:cn.mapway.ui.client.widget"
             xmlns:widget="urn:import:cn.mapway.gwt_template.client.workspace.widget">
    <ui:style>

        .top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 8px;
            gap: 1rem;
        }

        .box {
            padding: 20px;
        }</ui:style>
    <g:DockLayoutPanel>
        <g:south size="68">
            <dialog:SaveBar ui:field="saveBar"/>
        </g:south>
        <g:center>
            <g:ScrollPanel addStyleNames="{style.box}">
                <g:VerticalPanel width="100%" spacing="4">
                    <g:HTMLPanel addStyleNames="{style.top}">
                        <g:HorizontalPanel verticalAlignment="middle" spacing="4">
                            <widget1:Header>主题</widget1:Header>
                            <widget1:AiTextBox width="280px" ui:field="txtName"/>
                        </g:HorizontalPanel>
                        <g:HorizontalPanel verticalAlignment="middle" spacing="4">
                            <widget1:Header>重要程度</widget1:Header>
                            <widget:TaskPriorityDropdown ui:field="ddlPriority"/>
                        </g:HorizontalPanel>
                    </g:HTMLPanel>
                    <g:HTMLPanel addStyleNames="{style.top}">
                        <widget1:Header>会议地点</widget1:Header>
                        <widget1:AiTextBox ui:field="txtLocation"/>
                    </g:HTMLPanel>
                    <g:HTMLPanel addStyleNames="{style.top}">
                        <widget1:Header>参会人员</widget1:Header>
                        <widget1:AiTextBox ui:field="txtParticipate"/>
                    </g:HTMLPanel>
                    <g:HTMLPanel addStyleNames="{style.top}">
                        <g:TextArea addStyleNames="ai-input" width="100%" height="200px" ui:field="txtBody"/>
                    </g:HTMLPanel>
                </g:VerticalPanel>
            </g:ScrollPanel>

        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>