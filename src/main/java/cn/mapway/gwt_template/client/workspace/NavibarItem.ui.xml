<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style type="cn.mapway.gwt_template.client.workspace.NavibarItem.SStyle">
        .box {
            display: flex;
            align-items: center;
            gap: 6px;
            /* 增加垂直和水平 Padding，使背景块更显眼 */
            padding: 6px 12px;
            cursor: pointer;
            border-radius: 6px;
            transition: all 0.2s cubic-bezier(0.645, 0.045, 0.355, 1);
            color: #595959;
            /* 确保即使文字不多，背景也有最小宽度 */
            min-width: 40px;
        }

        .box:hover {
            background-color: #e6f7ff;
            color: #1890ff;
            box-shadow: inset 0 0 0 1px #91d5ff; /* 内部描边，不占用空间但视觉极强 */
        }

        /* 选中态：比如当前页面 */
        .box[select="true"] {
            color: #262626;
            font-weight: 600;
        }

        .icon {
            font-size: 16px;
        }

        .name {
            font-size: 14px;
            white-space: nowrap;
        }

        .next {
            color: #bfbfbf;
            /* 使用专门的 Unicode 字符：› (U+203A) */
            font-size: 18px;
            margin-left: 4px;
            font-family: "Segoe UI", "Apple Color Emoji", sans-serif;
            user-select: none;
        }

        .hideNext {
            display: none;
        }
    </ui:style>
    <g:HTMLPanel ui:field="container" addStyleNames="{style.box}">
        <widget:FontIcon ui:field="icon" addStyleNames="{style.icon}"/>
        <g:Label ui:field="lbName" addStyleNames="{style.name}"/>
        <g:Label ui:field="lbNext" addStyleNames="{style.next}"/>
    </g:HTMLPanel>
</ui:UiBinder>