<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        .box {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 4px;
            padding: 0 8px;
            line-height: 38px;
            border-radius: 4px;
            background-color: #f0f0f0;
        }

        .box:HOVER {
            background-color: skyblue;
        }

        .name {

        }

    </ui:style>
    <g:HTMLPanel addStyleNames="{style.box}">
        <widget:FontIcon ui:field="icon"/>
        <g:Label ui:field="lbName" addStyleNames="{style.name}"/>
        <g:Label ui:field="lbNext"/>
    </g:HTMLPanel>
</ui:UiBinder>