<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'>
    <ui:style>
        .box {
            overflow: auto;
            padding: 0;
            position: relative;
        }

        .content {
            position: absolute;
            inset: 10px;
        }</ui:style>
    <g:HTMLPanel ui:field="root" addStyleNames="{style.box}">
        <g:HTML ui:field="body" addStyleNames="markdown-body {style.content}">
        </g:HTML>
    </g:HTMLPanel>
</ui:UiBinder>