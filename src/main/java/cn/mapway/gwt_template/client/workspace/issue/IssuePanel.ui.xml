<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:widget="urn:import:cn.mapway.gwt_template.client.workspace.widget"
             xmlns:issue="urn:import:cn.mapway.gwt_template.client.workspace.issue"
             xmlns:panel="urn:import:cn.mapway.ui.client.widget.panel"
             xmlns:widget2="urn:import:cn.mapway.ui.client.widget"
             xmlns:buttons="urn:import:cn.mapway.ui.client.widget.buttons"
             xmlns:desktop="urn:import:cn.mapway.gwt_template.client.desktop">
    <ui:style>
        .row {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .title {
            font-size: 1.4rem;
            font-weight: bold;
            border: solid 1px transparent;
            border-radius: 6px;
            padding: 6px 4px;
            width: 100%;
        }

        .title:HOVER {
            border: solid 1px #eee;
            background-color: #f0f0f0;
        }

        .title:focus {
            outline: solid 1px brown;
        }

        .toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px;
        }

        .tip {
            color: #444;
            font-size: 0.9rem;
        }

        .body {
            margin-top: 10px;
            padding: 10px;
            border-radius: 6px;
            border: solid 1px #e0e0e0;
            height: 180px;
            overflow: auto;
        }

        .top {
            padding: 5px 15px;
        }

        .commentBottom {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 10px;
        }



        .container {
            padding: 10px;
        }</ui:style>
    <g:LayoutPanel ui:field="root">
        <g:layer>
            <g:DockLayoutPanel visible="false" ui:field="main">
                <g:north size="300">
                    <g:HTMLPanel addStyleNames="{style.top}">
                        <g:HTMLPanel addStyleNames="{style.row}">
                            <widget:EditableLabel addStyleNames="{style.title}" ui:field="txtName"/>
                        </g:HTMLPanel>
                        <g:HTMLPanel addStyleNames="{style.row}">
                            <g:HorizontalPanel spacing="4" verticalAlignment="middle">
                                <widget2:Header>状态</widget2:Header>
                                <issue:IssueStateDropdown ui:field="ddlState"/>
                            </g:HorizontalPanel>
                            <g:HorizontalPanel spacing="4" verticalAlignment="middle">
                                <widget2:Header>优先级</widget2:Header>
                                <widget:TaskPriorityDropdown ui:field="ddlPriority"/>
                            </g:HorizontalPanel>
                            <issue:AssignUserPanel ui:field="charger"/>
                        </g:HTMLPanel>
                        <widget:MarkdownBox ui:field="markdownBox" addStyleNames="{style.body}"/>
                    </g:HTMLPanel>
                </g:north>
                <g:north size="0">
                    <g:HTMLPanel ui:field="saveBar" addStyleNames="{style.toolbar}">
                        <g:Label ui:field="tip" addStyleNames="{style.tip}"/>
                        <buttons:AiButton ui:field="btnReopen" type="danger">重新打开</buttons:AiButton>
                        <buttons:AiButton ui:field="btnSave" type="warning">更新</buttons:AiButton>
                    </g:HTMLPanel>
                </g:north>
                <g:south size="0">
                    <g:HTMLPanel>
                        <g:HTMLPanel ui:field="inputTools" addStyleNames="{style.commentBottom}">
                            <widget2:Header>重新分配任务</widget2:Header>
                            <issue:AssignUserPanel ui:field="assignTo"/>
                            <buttons:AiButton type="success" ui:field="btnClose">关闭问题</buttons:AiButton>
                        </g:HTMLPanel>
                    </g:HTMLPanel>
                </g:south>
                <g:center>
                    <g:ScrollPanel addStyleNames="ai-border-top" ui:field="scroller">
                        <g:HTMLPanel ui:field="commentContainer" addStyleNames="{style.container}"/>
                    </g:ScrollPanel>
                </g:center>
            </g:DockLayoutPanel>
        </g:layer>
        <g:layer left="0" right="0" bottom="0" height="150">
            <desktop:SmartEditor ui:field="editor"/>
        </g:layer>
        <g:layer>
            <panel:MessagePanel ui:field="messagePanel"/>
        </g:layer>
    </g:LayoutPanel>
</ui:UiBinder>