<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        .box {
            display: grid;
            grid-template-columns: 100px 1fr 160px 90px;
            align-items: center;
            gap: 0.5rem;
            padding: 0 20px;
            height: 100%;
        }
    </ui:style>
    <g:DockLayoutPanel>
        <g:north size="50">
            <g:HTMLPanel addStyleNames="popup-top-panel">
                <g:Label addStyleNames="popup-header" ui:field="lbHeader"/>
            </g:HTMLPanel>
        </g:north>
        <g:north size="70">
            <g:HTMLPanel addStyleNames="{style.box}">
                <widget:Header>资源目录名称</widget:Header>
                <widget:AiTextBox ui:field="txtName"/>
                <widget:AiTextBox ui:field="txtColor"/>
                <g:Button ui:field="btnSave">保存</g:Button>
            </g:HTMLPanel>
        </g:north>
        <g:center>
            <g:FlexTable ui:field="memberTable">

            </g:FlexTable>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>