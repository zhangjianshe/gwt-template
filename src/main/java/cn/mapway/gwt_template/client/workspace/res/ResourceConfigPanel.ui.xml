<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        .box {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.5rem;
            padding: 0 20px;
            height: 100%;
        }
    </ui:style>
    <g:DockLayoutPanel>
        <g:north size="50">
            <g:HTMLPanel addStyleNames="popup-top-panel">
                <g:Label addStyleNames="popup-header" ui:field="lbHeader"/>
            </g:HTMLPanel>
        </g:north>
        <g:north size="70">
            <g:HTMLPanel addStyleNames="{style.box}">
                <widget:Header>分类名称</widget:Header>
                <widget:AiTextBox ui:field="txtName"/>
                <widget:Header>颜色</widget:Header>
                <widget:AiTextBox ui:field="txtColor" width="120px"/>
                <widget:Header>排序</widget:Header>
                <widget:AiTextBox ui:field="txtRank" width="50px"/>
                <g:Button ui:field="btnSave">保存</g:Button>
            </g:HTMLPanel>
        </g:north>
        <g:center>
            <g:FlexTable ui:field="memberTable">

            </g:FlexTable>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>