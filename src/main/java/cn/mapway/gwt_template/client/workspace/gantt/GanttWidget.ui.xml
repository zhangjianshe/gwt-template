<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:gantt="urn:import:cn.mapway.gwt_template.client.workspace.gantt"
             xmlns:task="urn:import:cn.mapway.gwt_template.client.workspace.task">
    <ui:style>

        .tools {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding: 0 4px;
        }

        .right {
            border-left: solid 2px #f0f0f0;
        }</ui:style>
    <g:LayoutPanel ui:field="root">
        <g:layer>
            <gantt:GanttChart width="100%" height="100%" ui:field="chart"/>
        </g:layer>
    </g:LayoutPanel>
</ui:UiBinder>