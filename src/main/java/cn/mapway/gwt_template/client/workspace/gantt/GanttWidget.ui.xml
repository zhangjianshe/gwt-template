<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:gantt="urn:import:cn.mapway.gwt_template.client.workspace.gantt"
             xmlns:task="urn:import:cn.mapway.gwt_template.client.workspace.task">
    <ui:style>

        .tools {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding: 0 4px;
        }

        .right {
            border-left: solid 2px #f0f0f0;
        }</ui:style>
    <g:LayoutPanel ui:field="root">
        <g:layer>
            <gantt:GanttChart width="100%" height="100%" ui:field="chart"/>
        </g:layer>
        <g:layer right="0" top="0" height="30" width="220">
            <g:HTMLPanel addStyleNames="{style.tools}">
                <g:Button ui:field="btnToday" addStyleNames="ai-small">今天</g:Button>
                <g:Button ui:field="btnTask" addStyleNames="ai-small">详情</g:Button>
            </g:HTMLPanel>
        </g:layer>
        <g:layer right="0" top="66" bottom="0" width="0">
            <task:DevTaskEditor ui:field="taskPanel" addStyleNames="{style.right}"/>
        </g:layer>
    </g:LayoutPanel>
</ui:UiBinder>