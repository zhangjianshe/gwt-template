<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:task="urn:import:cn.mapway.gwt_template.client.workspace.task"
             xmlns:widget2="urn:import:cn.mapway.gwt_template.client.workspace.widget"
             xmlns:buttons="urn:import:cn.mapway.ui.client.widget.buttons" xmlns:ace="urn:import:cn.mapway.ace.client">
    <ui:style>


        .charger {
            position: absolute;
            left: 10px;
            top: 30px;
            width: 70px;
            height: 140px;
            border-radius: 8px;
        }

        .body {
            background-color: white;
        }

        .top {
            position: relative;
            width: 100%;
            height: 100%;
        }

        .name {
            position: absolute;
            left: 90px;
            top: 60px;
            right: 10px;
            height: 36px;
            width: auto !important;
        }

        .kind {
            position: absolute;
            left: 90px;
            top: 20px;
            right: 10px;
            height: 36px;
        }

        .back {
            position: absolute;
            left: 0;
            top: 0;
            right: 0;
            height: 125px;
            background-color: brown;
        }

        .tip {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 300px;
        }

        .bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-top: solid 1px #f0f0f0;
        }</ui:style>
    <g:DockLayoutPanel addStyleNames="{style.body}" ui:field="root">
        <g:south size="56">
            <g:HTMLPanel addStyleNames="{style.bar}">
                <buttons:AiButton ui:field="btnCreateSub">创建子任务</buttons:AiButton>
                <buttons:AiButton ui:field="btnCreate">创建下一个</buttons:AiButton>
                <buttons:AiButton ui:field="btnSave">保存</buttons:AiButton>
                <buttons:AiButton ui:field="btnClose">关闭</buttons:AiButton>
            </g:HTMLPanel>
        </g:south>
        <g:north size="120">
            <g:HTMLPanel ui:field="container">
                <g:HTMLPanel ui:field="tip" addStyleNames="{style.tip}">
                    <g:Label>请选择任务编辑</g:Label>
                </g:HTMLPanel>
                <g:HTMLPanel ui:field="editor" addStyleNames="{style.top}">
                    <div class="{style.back}" ui:field="back"/>
                    <task:ProjectMemberWidget ui:field="member" addStyleNames="{style.charger}"/>
                    <g:TextBox ui:field="txtName" addStyleNames="ai-input {style.name}"/>
                    <widget2:TaskKindDropdown width="" ui:field="ddlKind" addStyleNames="{style.kind}"/>
                </g:HTMLPanel>
            </g:HTMLPanel>
        </g:north>
        <g:center>
            <g:TabLayoutPanel ui:field="editArea" barHeight="50">
                <g:tab>
                    <g:header>简介</g:header>
                    <g:LayoutPanel>
                        <g:layer>
                            <ace:AceEditor ui:field="txtSummary"/>
                        </g:layer>
                    </g:LayoutPanel>
                </g:tab>
            </g:TabLayoutPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>