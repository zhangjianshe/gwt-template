<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:task="urn:import:cn.mapway.gwt_template.client.workspace.task"
             xmlns:widget2="urn:import:cn.mapway.gwt_template.client.workspace.widget"
             xmlns:buttons="urn:import:cn.mapway.ui.client.widget.buttons">
    <ui:style>
        .body {
            background-color: white;
        }


        /* 右侧属性面板：谈谈的灰背景 */
        .right_sidebar {
            width: 300px;
            background-color: #fafafa;
            border-radius: 8px;
            padding: 20px;
            border: 1px solid #f0f0f0;
        }

        .summary_area {
            margin: 15px;
            border: solid 1px #e0e0e0;
            border-radius: 8px;
            padding: 10px;
            background-color: white;
        }

        /* 侧边栏条目布局 */
        .property_group {
            margin-bottom: 20px;
        }

        .property_label {
            font-size: 12px;
            color: #999;
            margin-bottom: 6px;
            display: block;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background-color: #f5f5f5; /* 经典的谈谈灰 */
            border-top: 1px solid #e5e5e5;
            padding: 0 24px;
            height: 100%;
            gap: 12px;
        }

        .title-input-style {
            border: 1px solid #e0e0e0;
            font-size: 20px;
            font-weight: bold;
            width: 100%;
            background: transparent;
            margin-bottom: 10px;
            padding: 10px;
            border-radius: 6px;
        }

        .title-input-style:focus {
            border: 1px solid #e0e0e0;
            background: white;
        }

        .content {
            padding: 15px;
        }
    </ui:style>

    <g:DockLayoutPanel addStyleNames="{style.body}" ui:field="root">
        <g:south size="64">
            <g:HTMLPanel addStyleNames="{style.bar}">
                <g:Label styleName="ai-message">Ctrl+S(保存退出) Esc(退出不保存)</g:Label>
                <g:HorizontalPanel>
                    <buttons:AiButton ui:field="btnSave">保存更改</buttons:AiButton>
                    <buttons:AiButton ui:field="btnClose">取消</buttons:AiButton>
                </g:HorizontalPanel>
            </g:HTMLPanel>
        </g:south>
        <g:east size="300">
            <g:HTMLPanel addStyleNames="{style.right_sidebar}">
                <div class="{style.property_group}">
                    <span class="{style.property_label}">负责人</span>
                    <task:ProjectMemberWidget imageWidth="130" ui:field="member"/>
                </div>
                <div class="{style.property_group}">
                    <span class="{style.property_label}">任务状态</span>
                    <widget2:TaskStatusDropdown ui:field="ddlStatus" width="100%"/>
                </div>
                <div class="{style.property_group}">
                    <span class="{style.property_label}">优先级</span>
                    <widget2:TaskPriorityDropdown ui:field="ddlPriority" width="100%"/>
                </div>

                <div class="{style.property_group}">
                    <span class="{style.property_label}">任务类型</span>
                    <widget2:TaskKindDropdown ui:field="ddlKind" width="100%"/>
                </div>
            </g:HTMLPanel>
        </g:east>
        <g:north size="60">
            <g:HTMLPanel addStyleNames="{style.content}">
                <g:TextBox ui:field="txtName" styleName="{style.title-input-style}"/>
            </g:HTMLPanel>
        </g:north>
        <g:center>
            <widget2:MarkdownBox  ui:field="txtSummary" styleName="{style.summary_area}"/>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>