<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:dialog="urn:import:cn.mapway.ui.client.widget.dialog"
             xmlns:tree="urn:import:cn.mapway.ui.client.widget.tree"
             xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <g:DockLayoutPanel>
        <g:north size="50">
            <g:HorizontalPanel height="100%" addStyleNames="ai-border-bottom" horizontalAlignment="center" verticalAlignment="middle" width="100%">
                <widget:SearchBox width="150px" ui:field="searchBox"/>
            </g:HorizontalPanel>
        </g:north>
        <g:south size="68">
            <dialog:SaveBar ui:field="saveBar"/>
        </g:south>
        <g:center>
            <g:ScrollPanel>
                <g:HTMLPanel ui:field="list">

                </g:HTMLPanel>
            </g:ScrollPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>