<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:panel="urn:import:cn.mapway.ui.client.widget.panel">
    <ui:style>
        .container {
            padding: 30px;
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            align-content: flex-start;
        }
        .scroll {
            background-color: #f5f7fa;
        }
    </ui:style>
    <g:DockLayoutPanel>
        <g:center>
            <g:ScrollPanel addStyleNames="{style.scroll}">
                <g:HTMLPanel ui:field="cardContainer" addStyleNames="{style.container}">
                    <panel:MessagePanel visible="false" ui:field="messagePanel"/>
                </g:HTMLPanel>
            </g:ScrollPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>