<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget"
             xmlns:res="urn:import:cn.mapway.gwt_template.client.workspace.res">
    <ui:style>
        .top {
            border-bottom: solid 1px #f0f0f0;
            display: grid;
            align-items: center;
            grid-template-columns: 50px 2fr 1fr 60px;
        }

        .header {
            justify-self: center;
        }</ui:style>
    <g:DockLayoutPanel>
        <g:north size="90">
            <g:HTMLPanel addStyleNames="{style.top}">
                <widget:Header addStyleNames="{style.header}">头像</widget:Header>
                <widget:Header>用户</widget:Header>
                <widget:Header>小组</widget:Header>
                <g:HTMLPanel>
                    <res:PermissionHeader ui:field="header"/>
                </g:HTMLPanel>
            </g:HTMLPanel>
        </g:north>
        <g:center>
            <g:ScrollPanel>
                <g:HTMLPanel ui:field="list">

                </g:HTMLPanel>
            </g:ScrollPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>