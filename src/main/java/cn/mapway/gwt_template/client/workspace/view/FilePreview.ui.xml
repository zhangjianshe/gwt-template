<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        .top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 0 10px;
            border-bottom: solid 1px #e0e0e0;
            background-color: #f0f0f0;
        }</ui:style>
    <g:DockLayoutPanel>
        <g:north size="40">
            <g:HTMLPanel addStyleNames="{style.top}">
                <widget:Header ui:field="lbName" addStyleNames="ai-code"/>
                <g:HorizontalPanel ui:field="toolBar">
                </g:HorizontalPanel>
            </g:HTMLPanel>
        </g:north>
        <g:center>
            <g:LayoutPanel ui:field="contentPanel"/>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>