<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        .top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 0 10px;
            border-bottom: solid 1px #e0e0e0;
            background-color: #f0f0f0;
        }

        /* 超长文本省略 + 手型指针 */
        .linkStyle {
            max-width: 400px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            display: inline-block;
            vertical-align: middle;
        }

        /* 复制按钮样式 */
        .copyBtn {
            display: inline-block;
            margin-left: 8px;
            cursor: pointer;
            color: #666;
            vertical-align: middle;
            transition: color 0.2s;
        }

        .copyBtn:hover {
            color: #1890ff; /* 悬停高亮蓝 */
        }
    </ui:style>
    <g:DockLayoutPanel ui:field="root">
        <g:north size="40">
            <g:HTMLPanel addStyleNames="{style.top}">
                <widget:Header ui:field="lbName" addStyleNames="ai-code"/>
                <g:HTMLPanel addStyleNames="url-copy-box">
                    <g:Label ui:field="lbLink" addStyleNames="{style.linkStyle}"/>
                    <!-- 复制图标按钮 -->
                    <g:HTML ui:field="btnCopy" addStyleNames="{style.copyBtn}" title="复制链接">
                        [复制链接地址]
                    </g:HTML>
                </g:HTMLPanel>
                <g:HorizontalPanel ui:field="toolBar">
                </g:HorizontalPanel>
            </g:HTMLPanel>
        </g:north>
        <g:center>
            <g:LayoutPanel ui:field="contentPanel"/>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>