<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'>

    <ui:style type="cn.mapway.gwt_template.client.widget.gridstack.GridStackPanel.SStyle">

        /* 1. 总大屏背景：强行穿透外部 GWT LayoutPanel 赋予它底色 */
        .gridContainer {
            background: #f4f6f9 !important; /* 加 !important 确保覆盖掉任何白底继承 */
            position: absolute;
            left: 0px;
            right: 0px;
            top: 0px;
            bottom: 0px !important;
            height: auto !important;
            overflow: hidden;
        }

        /* 2. 第三方原生内容容器：交还给原生库，仅补充基础 UI */
        :global(.grid-stack-item-content) {
            background: #ffffff !important;
            border: 1px solid #e3e8ee !important;
            box-shadow: none !important;
            flex-direction: column !important;
            overflow: hidden !important;

        }

        .dashboard-item {
            background-color: white;
            display: grid;
            grid-template-rows: 40px 1fr;
            border: solid 1px #e0e0e0;
        }

        .dashboard-item-hide-header {
            background-color: white;
            display: grid;
            grid-template-rows: 1fr;
            border: solid 1px #e0e0e0;
        }

        .design{
            border: solid 1px skyblue;
        }

        /* 3. 拖拽手柄头部 */
        .dashboard-item-header {
            background: #fafafc;
            padding: 10px 14px;
            cursor: move;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #e3e8ee;
            color: #464c5b;
            font-size: 14px;
            font-weight: 600;
            user-select: none;
            flex-shrink: 0;
            box-sizing: border-box;
            overflow: hidden !important;
        }


        :global(.grid-stack-item-content) > div:last-child {
            flex-grow: 1;
            flex-shrink: 1;
            width: 100%;
            height: 0; /* 极其关键：配合 flex-grow 让高度基于剩余空间自适应，而不是基于百分比死撑 */
            box-sizing: border-box;
            padding: 12px;
            background: #ffffff;
            overflow: auto; /* 只有当你的 Hello world 组件真的很长时，这里才允许局部滚动，卡片外层不再滚动 */
        }
    </ui:style>

    <g:FlowPanel ui:field="container" styleName="{style.gridContainer} grid-stack"/>

</ui:UiBinder>