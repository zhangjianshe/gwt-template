<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>

        .box {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .uploader {
            border-radius: 50%;
            padding: 8px;
        }

        .uploader:HOVER {
            background-color: #95d475;
            color: white;
        }
    </ui:style>
    <g:HTMLPanel addStyleNames="{style.box}">
        <widget:FontIcon fontSize="18" addStyleNames="{style.uploader}" ui:field="btnUploader"/>
    </g:HTMLPanel>
</ui:UiBinder>