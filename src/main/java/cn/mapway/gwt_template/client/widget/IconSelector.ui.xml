<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        .top {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .flow {
            padding: 10px;
        }</ui:style>
    <g:DockLayoutPanel>
        <g:north size="50">
            <g:HTMLPanel addStyleNames="{style.top}">
                <widget:Header>搜索</widget:Header>
                <widget:SearchBox width="100px" ui:field="searchBox"/>
            </g:HTMLPanel>
        </g:north>
        <g:center>
            <g:ScrollPanel>
                <g:FlowPanel ui:field="container" addStyleNames="{style.flow}">

                </g:FlowPanel>
            </g:ScrollPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>