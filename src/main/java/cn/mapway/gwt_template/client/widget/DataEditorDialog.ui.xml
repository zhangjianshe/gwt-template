<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:dialog="urn:import:cn.mapway.ui.client.widget.dialog"
             xmlns:ace="urn:import:cn.mapway.ace.client"
             xmlns:widget="urn:import:cn.mapway.ui.client.widget"
             xmlns:inspector="urn:import:cn.mapway.ui.client.mvc.attribute.editor.inspector">
    <ui:style>
        .nodrag {
            font-family:Iosevka, courier, monospace;
            resize: none;
            line-height: 1.3em;
        }
    </ui:style>
    <g:DockLayoutPanel ui:field="root">
        <g:south size="68">
            <dialog:SaveBar ui:field="saveBar"/>
        </g:south>
        <g:north size="45">
            <g:HorizontalPanel verticalAlignment="middle" ui:field="tools" spacing="4">
                <widget:Header>语言</widget:Header>
                <inspector:LanguageDropdown ui:field="language" width="150px"/>
            </g:HorizontalPanel>
        </g:north>
        <g:center>
            <ace:AceEditor ui:field="dataEditor" width="100%" height="100%" styleName="{style.nodrag}"/>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>
