<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        @eval BACK_HOVER "var(--color-background-hover)";
        .box {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 10px;
        }

        .title {
            font-weight: bold;
            font-size: 1rem;
        }

        .btn {
            font-size: 14px;
            border-radius: 3px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 26px;
            height: 26px;
        }

        .btn:hover {
            background-color: BACK_HOVER;
        }

        .tools {
            display: inline-flex;
            align-items: center;
            justify-content: flex-end;
        }</ui:style>
    <g:HTMLPanel ui:field="root" addStyleNames="{style.box}">
        <g:Label ui:field="txtTitle" addStyleNames="{style.title}"/>
        <g:HTMLPanel addStyleNames="{style.tools}">
            <widget:FontIcon ui:field="btnConfig" addStyleNames="{style.btn}"/>
            <widget:FontIcon ui:field="btnDelete" addStyleNames="{style.btn}"/>
        </g:HTMLPanel>
    </g:HTMLPanel>
</ui:UiBinder>