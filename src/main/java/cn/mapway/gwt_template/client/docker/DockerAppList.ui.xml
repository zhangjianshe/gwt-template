<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:widget="urn:import:cn.mapway.gwt_template.client.widget"
             xmlns:buttons="urn:import:cn.mapway.ui.client.widget.buttons"
             xmlns:tree="urn:import:cn.mapway.ui.client.widget.tree">
    <ui:style>

        .top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 4px;
        }</ui:style>
    <g:DockLayoutPanel>
        <g:north size="60">
            <g:HTMLPanel addStyleNames="{style.top}">
                <widget:Head>应用列表</widget:Head>
                <buttons:AiButton type="warning" ui:field="btnApp">添加应用</buttons:AiButton>
            </g:HTMLPanel>
        </g:north>
        <g:center>
            <g:ScrollPanel>
                <tree:Tree ui:field="list"/>
            </g:ScrollPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>