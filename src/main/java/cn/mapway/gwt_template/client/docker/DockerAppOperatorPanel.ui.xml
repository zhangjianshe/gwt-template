<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:buttons="urn:import:cn.mapway.ui.client.widget.buttons"
             xmlns:dialog="urn:import:cn.mapway.ui.client.widget.dialog"
             xmlns:xterm="urn:import:cn.mapway.xterm.client"
             xmlns:tree="urn:import:cn.mapway.ui.client.widget.tree"
             xmlns:widget="urn:import:cn.mapway.ui.client.widget">

    <ui:style type="cn.mapway.gwt_template.client.docker.DockerAppOperatorPanel.SStyle">
        .box {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 10px;
        }

        .sizeLabel {
            color: #888;
            background: #f5f5f5;
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 10px;
            line-height: 32px;
        }
    </ui:style>

    <g:DockLayoutPanel ui:field="root">
        <!-- 底部保存/操作状态栏 -->
        <g:south size="0">
            <dialog:SaveBar ui:field="saveBar" enableSave="false" showSave="false"/>
        </g:south>

        <!-- 顶部标题与控制按钮栏 -->
        <g:north size="50">
            <g:HTMLPanel addStyleNames="{style.box} ai-border-bottom">
                <g:HorizontalPanel spacing="4" verticalAlignment="middle">
                    <buttons:AiButton ui:field="lbTitle">应用详情</buttons:AiButton>
                    <buttons:AiButton ui:field="btnRestart">重启应用</buttons:AiButton>
                    <buttons:AiButton ui:field="btnStop">停止应用</buttons:AiButton>
                    <g:Label ui:field="lbSize" addStyleNames="{style.sizeLabel}"/>
                </g:HorizontalPanel>


                <g:HorizontalPanel spacing="4" verticalAlignment="middle">
                    <buttons:AiButton visible="false" ui:field="btnStartService">启动服务</buttons:AiButton>
                    <widget:AiTextBox visible="false" ui:field="txtCommand" width="160" placeholder="/bin/bash"/>
                    <buttons:AiButton visible="false" ui:field="btnExec">进入服务</buttons:AiButton>
                </g:HorizontalPanel>
            </g:HTMLPanel>
        </g:north>

        <!-- 左侧导航树 (例如: 日志/控制台/文件/配置) -->
        <g:west size="160">
            <g:ScrollPanel addStyleNames="ai-border-right">
                <tree:Tree ui:field="list"/>
            </g:ScrollPanel>
        </g:west>

        <!-- 中间终端/主要内容展示区 -->
        <g:center>
            <xterm:TerminalPanel width="100%" height="100%" ui:field="terminal"/>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>