<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget"
>
    <ui:style>
        @eval BK_HOVER "var(--color-background-hover)";
        @eval BK_SELECTED "var(--color-background-selected)";
        .box {
            display: grid;
            grid-template-columns: 30px 1fr 90px;
            align-items: center;
            gap: 4px;
            min-height: 40px;
            border-radius: 6px;
            padding: 4px;
            width: 100%;
        }

        .box:HOVER {
            background-color: BK_HOVER;
        }

        .box[select="true"] {
            background-color: BK_SELECTED;
        }

        .size {
            justify-self: flex-end;
            color: cadetblue;
        }</ui:style>
    <g:HTMLPanel addStyleNames="{style.box}">
        <widget:FontIcon ui:field="icon" fontSize="28"/>
        <g:Label ui:field="lbName"/>
        <g:Label ui:field="lbSize" addStyleNames="{style.size}"/>
    </g:HTMLPanel>
</ui:UiBinder>