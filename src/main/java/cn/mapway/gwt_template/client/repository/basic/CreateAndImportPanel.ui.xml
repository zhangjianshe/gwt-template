<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget"
             xmlns:dialog="urn:import:cn.mapway.ui.client.widget.dialog">
    <ui:style>
        .box {
            margin: 15px;
            border: solid 1px deepskyblue;
            border-radius: 6px;
        }


        .box1 {
            padding: 15px;
            display: grid;
            grid-template-columns: 100px 1fr;
            gap: 1rem;
            align-items: center;
        }
    </ui:style>
    <g:DockLayoutPanel>
        <g:south size="68">
            <dialog:SaveBar ui:field="saveBar" saveText="导入"/>
        </g:south>
        <g:center>
            <g:HTMLPanel addStyleNames="{style.box}">
                <g:HTMLPanel addStyleNames="{style.box1}">
                    <widget:Header>仓库地址</widget:Header>
                    <widget:AiTextBox placeholder="输入其他仓库的地址　比如 gitlab,github,gitee" ui:field="txtUrl"/>
                    <widget:Header>用户名</widget:Header>
                    <widget:AiTextBox placeholder="远端仓库认证信息" width="250px" ui:field="txtAuthorize"/>
                    <widget:Header>密码或TOKEN</widget:Header>
                    <widget:AiTextBox width="250px" ui:field="txtToken"/>
                    <widget:Header>新仓库的名称</widget:Header>
                    <widget:AiTextBox width="250px" ui:field="txtNewRepoName"/>
                </g:HTMLPanel>
            </g:HTMLPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>
