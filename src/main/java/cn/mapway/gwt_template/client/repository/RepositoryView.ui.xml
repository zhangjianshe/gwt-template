<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:widget="urn:import:cn.mapway.gwt_template.client.widget"
             xmlns:panel="urn:import:cn.mapway.ui.client.widget.panel">
    <ui:style>
        .top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: solid 1px #e0e0e0;
            padding: 0 15px;
        }
    </ui:style>
    <g:LayoutPanel ui:field="root">
        <g:layer left="0" top="0" right="0" height="50">
            <g:HTMLPanel addStyleNames="{style.top}" ui:field="toolbar">
                <g:HorizontalPanel ui:field="buttons" spacing="0">
                    <widget:IconButton height="50px" ui:field="btnCode"/>
                </g:HorizontalPanel>
                <widget:IconButton height="50px" ui:field="btnSetting"/>
                <panel:MessagePanel  debugId="sadsad" ui:field="messagePanel"/>
            </g:HTMLPanel>
        </g:layer>
        <g:layer left="0" bottom="0" right="0" top="50">
            <g:LayoutPanel ui:field="content">
            </g:LayoutPanel>
        </g:layer>
    </g:LayoutPanel>
</ui:UiBinder>