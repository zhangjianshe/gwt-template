<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:buttons="urn:import:cn.mapway.ui.client.widget.buttons"
             xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        .panel {
            display: grid;
            align-items: center;
            grid-template-columns: 160px 1fr;
            gap: 8px;
            padding: 15px;
        }
    </ui:style>
    <g:FlowPanel>
        <g:HTMLPanel ui:field="panel" addStyleNames="{style.panel}">
            <widget:Header>转移仓库</widget:Header>
            <buttons:AiButton width="350px" ui:field="btnTransfer">转移仓库</buttons:AiButton>
        </g:HTMLPanel>
    </g:FlowPanel>
</ui:UiBinder>