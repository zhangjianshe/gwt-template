<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:dialog="urn:import:cn.mapway.ui.client.widget.dialog"
             xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        .box {
            display: grid;
            padding: 15px;
            grid-template-columns: 100px 1fr;
            gap: 1rem;
            align-items: center;
            justify-content: flex-start;
        }

        .left {
            justify-self: flex-start;
        }

        .tip {
            font-style: italic;
            color: darkolivegreen;
            font-size: 0.8rem;
            padding: 0 4px;
        }

        .msg {
            padding: 10px 15px;
            border-radius: 6px;
            border: solid 1px skyblue;
            background-color: whitesmoke;
            color: gray;
        }
    </ui:style>
    <g:DockLayoutPanel>
        <g:south size="68">
            <dialog:SaveBar buttonWidth="120" saveText="创建仓库" ui:field="saveBar"/>
        </g:south>
        <g:center>
            <g:HTMLPanel>
                <g:HTMLPanel addStyleNames="ai-flex-panel" height="70px">
                    <g:Label addStyleNames="{style.msg}">开启一个新的仓库，总是一个不错的选择</g:Label>
                </g:HTMLPanel>
                <g:HTMLPanel addStyleNames="{style.box}">
                    <widget:Header addStyleNames="{style.left}">仓库代码</widget:Header>
                    <g:HorizontalPanel verticalAlignment="middle">
                        <widget:AiTextBox ui:field="txtName" width="180px"
                                          placeholder="比如 beijing_project通常是一个简洁的名字"/>
                        <g:Label ui:field="lbTip" addStyleNames="{style.tip}">*只允许使用英文字母和下划线和短横
                        </g:Label>
                    </g:HorizontalPanel>
                    <widget:Header addStyleNames="{style.left}">仓库名称</widget:Header>
                    <widget:AiTextBox ui:field="txtFullName"
                                      placeholder="这是一个仓库的全称"/>
                </g:HTMLPanel>

            </g:HTMLPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>