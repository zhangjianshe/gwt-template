<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget"
             xmlns:buttons="urn:import:cn.mapway.ui.client.widget.buttons">
    <ui:style>
        .box {
            margin: 15px;
            width: 700px;
            border: solid 1px deepskyblue;
            border-radius: 6px;
        }

        .top {
            height: 50px;
            background-color: skyblue;
            display: flex;
            align-items: center;
            padding: 0 15px;
            justify-content: space-between;
        }

        .box1 {
            padding: 15px;
            display: grid;
            grid-template-columns: 100px 1fr;
            gap: 1rem;
        }

        .msg {
            color: gray;
        }</ui:style>
    <g:HTMLPanel>
        <g:HTMLPanel addStyleNames="{style.box}">
            <g:HTMLPanel addStyleNames="{style.top}">
                <widget:Header>从其他仓库导入</widget:Header>
                <buttons:AiButton ui:field="btnImport">导入</buttons:AiButton>
            </g:HTMLPanel>
            <g:HTMLPanel addStyleNames="{style.box1}">
                <widget:Header>仓库地址</widget:Header>
                <widget:AiTextBox placeholder="输入其他仓库的地址　比如 gitlab,github,gitee" ui:field="txtUrl"/>
                <widget:Header>用户名</widget:Header>
                <widget:AiTextBox placeholder="远端仓库认证信息" width="200px" ui:field="txtAuthorize"/>
                <widget:Header>密码或TOKEN</widget:Header>
                <widget:AiTextBox width="200px" ui:field="txtToken"/>
                <g:Label>*</g:Label>
                <g:Label ui:field="lbMessage" addStyleNames="{style.msg}"/>
            </g:HTMLPanel>
        </g:HTMLPanel>
    </g:HTMLPanel>
</ui:UiBinder>
