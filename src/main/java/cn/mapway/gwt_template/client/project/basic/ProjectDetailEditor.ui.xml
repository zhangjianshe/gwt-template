<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:dialog="urn:import:cn.mapway.ui.client.widget.dialog"
             xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        .box {
            display: grid;
            padding: 15px;
            grid-template-columns: 100px 1fr;
            gap: 1rem;
            align-items: center;
            justify-content: flex-start;
        }

        .left {
            justify-self: flex-start;
        }

        .tip {
            font-style: italic;
            color: darkolivegreen;
            font-size: 0.8rem;
            padding: 0 4px;
        }

        .msg {
            padding: 10px 15px;
            border-radius: 6px;
            border: solid 1px skyblue;
            background-color: whitesmoke;
            color: gray;
        }
    </ui:style>
    <g:DockLayoutPanel>
        <g:south size="68">
            <dialog:SaveBar saveText="保存" ui:field="saveBar"/>
        </g:south>
        <g:center>
            <g:HTMLPanel>
                <g:HTMLPanel addStyleNames="{style.box}">
                    <widget:Header addStyleNames="{style.left}">项目全称</widget:Header>
                    <widget:AiTextBox ui:field="txtFullName" placeholder="这是一个项目的全称"/>
                    <widget:Header addStyleNames="{style.left}">项目介绍</widget:Header>
                    <g:TextArea ui:field="txtSummary" addStyleNames="ai-input" height="80px"/>
                    <widget:Header addStyleNames="{style.left}">项目标签</widget:Header>
                    <widget:AiTextBox ui:field="txtTags" placeholder="逗号分割"/>
                </g:HTMLPanel>
            </g:HTMLPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>