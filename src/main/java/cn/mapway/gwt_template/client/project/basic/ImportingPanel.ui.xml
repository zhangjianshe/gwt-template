<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'>
    <ui:style>
        .box {
            margin: 15px;
            width: 700px;
            border: solid 1px deepskyblue;
            border-radius: 6px;
            height: 300px;
        }

        .box1 {
            display: flex;
            align-items: center;
            justify-self: center;
            height: 300px;
        }</ui:style>
    <g:HTMLPanel>
        <g:HTMLPanel addStyleNames="{style.box}">
            <g:HTMLPanel addStyleNames="{style.box1}">
                <g:Label ui:field="lbMessage"/>
            </g:HTMLPanel>
        </g:HTMLPanel>
    </g:HTMLPanel>
</ui:UiBinder>