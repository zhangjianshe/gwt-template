<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        .login-container {
            background-color: #fff;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            width: 300px;
            position: absolute;
            right: 15%;
        }

        h2 {
            text-align: center;
            margin-bottom: 20px;
        }

        .input-group {
            margin-bottom: 15px;
        }

        .input-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
            padding-bottom: 10px;
        }

        .input-group input[type="text"],
        .input-group input[type="password"] {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 4px;
            box-sizing: border-box; /* Important for padding not to increase total width */
        }

        .login-button {
            width: 140px;
            padding: 10px;
            background-color: #007bff;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 16px;
            margin-top: 10px;
            line-height: 14px;
        }

        .login-button:hover {
            background-color: #0056b3;
        }

        .box {
            display: flex;
            align-items: center;
            justify-content: center;
            flex-flow: column;
        }

        .box1 {
            display: flex;
            align-items: center;
            justify-content: center;
            flex-flow: column;
            gap: 1rem;
            position: relative;
        }

        .msg {
            text-wrap: wrap;
            word-break: break-all;
            padding: 10px;
            line-height: 150%;
            color: brown;
            background-color: white;
            overflow: auto;
            border: solid 1px #f0f0f0;
            border-radius: 10px;
            box-shadow: 0 0 8px rgba(0, 0, 0, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 10px;
        }

        .background {
            object-fit: cover;
            object-position: center;
            width: 100%;
            height: 100%;
        }

        .version {
            color: gray;
            font-size: 0.9rem;
            font-family: Iosevka;
        }
    </ui:style>
    <g:LayoutPanel ui:field="root">
        <g:layer>
            <g:Image ui:field="background" addStyleNames="{style.background}"/>
        </g:layer>
        <g:layer>
            <g:HTMLPanel addStyleNames="{style.box1}" ui:field="page">
                <div class="{style.login-container}">
                    <h2>系统登录</h2>
                    <form method="POST" class="{style.box}">
                        <div class="{style.input-group}">
                            <label for="txtName">用户名</label>
                            <widget:AiTextBox name="txtName" ui:field="txtName"/>
                        </div>
                        <div class="{style.input-group}">
                            <label for="password">密码</label>
                            <widget:AiTextBox name="password" ui:field="txtPassword"/>
                        </div>
                        <g:Button addStyleNames="{style.login-button}" ui:field="btnLogin">登录</g:Button>
                    </form>
                </div>

            </g:HTMLPanel>
        </g:layer>
        <g:layer left="100" bottom="100" right="100" height="100">
            <g:Label ui:field="lbMessage" visible="false" addStyleNames="{style.msg}"/>
        </g:layer>
        <g:layer left="20" bottom="10" width="300" height="30">
            <g:Label ui:field="lbVersion" addStyleNames="{style.version}"/>
        </g:layer>
    </g:LayoutPanel>
</ui:UiBinder>