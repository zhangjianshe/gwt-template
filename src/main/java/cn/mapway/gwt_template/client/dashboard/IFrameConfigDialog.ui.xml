<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:dialog="urn:import:cn.mapway.ui.client.widget.dialog"
             xmlns:widget1="urn:import:cn.mapway.gwt_template.client.widget"
             xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        .box {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            margin: 15px;
        }

        .panel {
            padding: 25px;
        }</ui:style>
    <g:DockLayoutPanel>
        <g:south size="60">
            <dialog:SaveBar ui:field="saveBar"/>
        </g:south>
        <g:center>
            <g:HTMLPanel addStyleNames="{style.panel}">
                <g:HTMLPanel addStyleNames="{style.box}">
                    <widget1:Head>标题</widget1:Head>
                    <widget:AiTextBox ui:field="txtTitle"/>
                </g:HTMLPanel>
                <g:HTMLPanel addStyleNames="{style.box}">
                    <widget1:Head>URL</widget1:Head>
                    <widget:AiTextBox ui:field="txtUrl"/>
                </g:HTMLPanel>
            </g:HTMLPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>