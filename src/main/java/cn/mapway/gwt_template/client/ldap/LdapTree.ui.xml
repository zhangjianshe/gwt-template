<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget"
             xmlns:tree="urn:import:cn.mapway.ui.client.widget.tree">
    <ui:style>
        .box {
            display: flex;
            padding: 0 10px;
            align-items: center;
        }
    </ui:style>
    <g:DockLayoutPanel>
        <g:north size="50">
            <g:HTMLPanel addStyleNames="{style.box} ai-border-bottom">
                <widget:SearchBox ui:field="searchBox"/>
            </g:HTMLPanel>
        </g:north>
        <g:center>
            <g:ScrollPanel>
                <tree:Tree ui:field="ldapTree" width="100%"/>
            </g:ScrollPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>