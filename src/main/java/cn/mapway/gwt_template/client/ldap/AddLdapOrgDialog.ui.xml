<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:dialog="urn:import:cn.mapway.ui.client.widget.dialog"
             xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        .box {
            display: grid;
            grid-template-columns: 120px 1fr;
            padding: 20px;
            align-items: center;
            justify-content: center;
            gap: 1em;
        }
    </ui:style>
    <g:DockLayoutPanel>
        <g:south size="68">
            <dialog:SaveBar ui:field="saveBar"/>
        </g:south>
        <g:center>
            <g:HTMLPanel addStyleNames="{style.box}">
                <widget:Header>父节点名称</widget:Header>
                <widget:AiTextBox readOnly="true" ui:field="txtDn"/>
                <widget:Header>组织名称</widget:Header>
                <widget:AiTextBox placeholder="dev" ui:field="txtName"/>
                <widget:Header>组织描述</widget:Header>
                <widget:AiTextBox ui:field="txtDescription"/>
            </g:HTMLPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>