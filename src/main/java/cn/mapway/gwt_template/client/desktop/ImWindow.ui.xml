<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget"
             xmlns:desktop="urn:import:cn.mapway.gwt_template.client.desktop">
    <ui:style>
        .top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 15px;
        }
    </ui:style>
    <g:DockLayoutPanel>
        <g:north size="60">
            <g:HTMLPanel addStyleNames="{style.top} ai-border-bottom">
                <widget:Header ui:field="lbTitle">我的联系人</widget:Header>
                <g:Anchor ui:field="btnReturn" visible="false">返回</g:Anchor>
                <g:Anchor ui:field="btnSelectUser">选择用户</g:Anchor>
            </g:HTMLPanel>
        </g:north>
        <g:center>
            <desktop:UserMailboxPanel ui:field="mailboxPanel"/>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>