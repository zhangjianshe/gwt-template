<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        @eval HOVER_COLOR "var(--color-background-hover)";
        @eval SELECTED_COLOR "var(--color-background-selected)";
        .box {
            display: flex;
            width: 70px;
            height: 70px;
            overflow: hidden;
            align-items: center;
            justify-content: center;
            border-radius: 35px 35px;
        }

        .btn {
            border-radius: 50px 50px;
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: default;
        }

        .btn:HOVER {
            background-color: HOVER_COLOR;
        }

        .btn[select="true"] {
            background-color: SELECTED_COLOR;
            color: darkblue;
        }
    </ui:style>
    <g:HTMLPanel addStyleNames="{style.box}">
        <widget:FontIcon fontSize="40"  ui:field="icon" styleName="{style.btn}"/>
    </g:HTMLPanel>
</ui:UiBinder>