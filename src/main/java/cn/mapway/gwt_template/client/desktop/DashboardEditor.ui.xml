<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:dialog="urn:import:cn.mapway.ui.client.widget.dialog"
             xmlns:widget1="urn:import:cn.mapway.gwt_template.client.widget"
             xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>

        .box {
            padding: 20px;
            display: flex;
            gap: 0.5rem;
            flex-flow: column;
        }

        .row {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }</ui:style>
    <g:DockLayoutPanel>
        <g:south size="60">
            <dialog:SaveBar ui:field="saveBar"/>
        </g:south>
        <g:center>
            <g:HTMLPanel addStyleNames="{style.box}">
                <g:HTMLPanel addStyleNames="{style.row}">
                    <widget1:Head>面板名称</widget1:Head>
                    <widget:AiTextBox width="280px" ui:field="txtName"/>
                </g:HTMLPanel>
                <g:HTMLPanel addStyleNames="{style.row}">
                    <widget1:Head>排序</widget1:Head>
                    <widget:AiTextBox width="280px" ui:field="txtRank"/>
                </g:HTMLPanel>
            </g:HTMLPanel>

        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>