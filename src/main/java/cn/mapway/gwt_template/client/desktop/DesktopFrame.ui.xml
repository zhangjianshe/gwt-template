<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:desktop="urn:import:cn.mapway.gwt_template.client.desktop"
             xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        .box {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            height: 100%;
        }

        .btn {
            width: 160px;
            height: 160px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 1.1rem;
            border: solid 1px #f0f0f0;
        }

        .btn:HOVER {
            background-color: #e0e0e0;
        }

        .top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 10px;
        }

        .left {
            background-color: #e9eef6;
        }</ui:style>
    <g:DockLayoutPanel>
        <g:west size="400">
            <g:DockLayoutPanel addStyleNames="ai-border-right {style.left}">
                <g:north size="50">
                    <g:HTMLPanel addStyleNames="{style.top} ai-border-bottom">
                        <widget:Header ui:field="lbTitle"/>
                        <g:Button ui:field="btnReturn" visible="false">返回</g:Button>
                        <g:Button ui:field="btnSelectUser">选择用户</g:Button>
                    </g:HTMLPanel>
                </g:north>
                <g:center>
                    <desktop:UserMailboxPanel ui:field="mailboxPanel"/>
                </g:center>
            </g:DockLayoutPanel>

        </g:west>
        <g:center>
            <g:HTMLPanel ui:field="panel" addStyleNames="{style.box}">
                <g:Label ui:field="btnAdd" addStyleNames="{style.btn}">添加快捷方式</g:Label>
            </g:HTMLPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>