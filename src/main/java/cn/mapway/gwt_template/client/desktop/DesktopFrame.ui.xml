<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:desktop="urn:import:cn.mapway.gwt_template.client.desktop"
             xmlns:wiki="urn:import:cn.mapway.gwt_template.client.workspace.wiki"
>
    <ui:style>

        .toolspanel {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding: 0 10px;
        }</ui:style>
    <g:LayoutPanel>
        <g:layer>
            <g:TabLayoutPanel barHeight="50" ui:field="root">
                <g:tab>
                    <g:header>🖥️ 桌面</g:header>
                    <desktop:DashboardPanel ui:field="dashboard"/>
                </g:tab>
                <g:tab>
                    <g:header>🗓️ 工作日历</g:header>
                    <g:Label>工作日历</g:Label>
                </g:tab>
                <g:tab>
                    <g:header>✍️ Page editor</g:header>
                    <g:ScrollPanel>
                        <wiki:PageEditor ui:field="pageEditor"/>
                    </g:ScrollPanel>
                </g:tab>
            </g:TabLayoutPanel>
        </g:layer>
        <g:layer right="0" top="0" width="400" height="50">
            <g:HTMLPanel ui:field="toolsPanel" addStyleNames="{style.toolspanel}"/>
        </g:layer>
    </g:LayoutPanel>
</ui:UiBinder>