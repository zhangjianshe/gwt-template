<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:buttons="urn:import:cn.mapway.ui.client.widget.buttons">
    <ui:style>
        .box {
            /* 基础布局 */
            background: rgba(255, 255, 255, 0.65); /* 半透明白色底 */
            border-radius: 16px; /* 圆角 */
            padding: 24px;
            text-align: center;
            width: 160px;
            height: 160px;

            /* 毛玻璃核心：背景模糊 */
            -webkit-backdrop-filter: blur(10px);
            backdrop-filter: blur(10px);

            /* 边框和阴影，增加立体感 */
            border: 1px solid rgba(178, 178, 178, 0.4); /* 微亮的边框 */
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05); /* 柔和阴影 */

            /* 动效过渡 */
            transition: all 0.3s ease-out;
            cursor: pointer;
        }

        .box:HOVER {
            transform: translateY(-8px); /* 向上浮动 */
            background: rgba(255, 255, 255, 0.85); /* 增加不透明度 */
            box-shadow: 0 12px 30px rgba(47, 84, 235, 0.15); /* 阴影变深并带有一点品牌色 */
            border: 1px solid rgba(47, 84, 235, 0.2); /* 边框变品牌色 */
        }

        .img {
            object-fit: cover;
            width: 90px;
            height: 90px;
            border-radius: 4px;
            user-select: none;
        }

        .name {
            max-width: 140px;
            overflow: hidden;
            text-overflow: ellipsis;
            font-size: 18px;
            color: #1a2138; /* 深色字体 */
            margin: 0;
            transition: color 0.3s ease;
            font-weight: bold;
        }

        .name:hover {
            color: #2f54eb; /* 悬停时标题变色 */
        }

        .editor {
            position: absolute;
            right: 0;
            top: 0;
            left: 0;
            height: 30px;
            border-radius: 16px 16px 0 0;
            padding: 0 4px;
            background-color: rgba(0, 0, 0, 0.4);
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 1rem;
        }

        .btn {
            border-radius: 4px;
            width: 26px;
            height: 26px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: darkgreen;
        }

        .btn:HOVER {
            background-color: skyblue;
        }
    </ui:style>
    <g:HTMLPanel addStyleNames="{style.box}">
        <g:HTMLPanel ui:field="btnPan" visible="false" addStyleNames="{style.editor}">
            <buttons:DeleteButton addStyleNames="{style.btn}" color="white" ui:field="btnDelete" fontSize="24"/>
            <buttons:EditButton addStyleNames="{style.btn}" color="white" ui:field="btnEditor" fontSize="22"/>
        </g:HTMLPanel>
        <g:Image ui:field="image" addStyleNames="{style.img}"/>
        <g:Label ui:field="lbName" addStyleNames="{style.name}"/>
    </g:HTMLPanel>
</ui:UiBinder>