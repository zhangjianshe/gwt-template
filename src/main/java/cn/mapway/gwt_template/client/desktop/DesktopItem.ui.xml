<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:buttons="urn:import:cn.mapway.ui.client.widget.buttons">
    <ui:style>
        @eval HOVER_BACK "var(--color-background-hover)";
        @eval SELECTED_BACK "var(--color-background-selected)";
        .box {
            display: grid;
            grid-template-rows: 1fr 32px;
            align-items: center;
            justify-content: center;
            width: 120px;
            height: 120px;
            border-radius: 6px;
            position: relative;
        }

        .box:HOVER {
            background-color: HOVER_BACK;
        }

        .box[select="true"] {
            background-color: SELECTED_BACK;
        }


        .name {
            line-height: 42px;
        }

        .img {
            align-self: center;
            justify-self: anchor-center;
            width: 60px;
            height: 60px;
        }

        .btn {

        }

        .editor {
            position: absolute;
            left: 0;
            top: 0;
            right: 0;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </ui:style>
    <g:HTMLPanel  ui:field="root" addStyleNames="{style.box}">
        <g:HTMLPanel ui:field="btnPan" visible="false" addStyleNames="{style.editor}">
            <buttons:DeleteButton addStyleNames="{style.btn}" color="white" ui:field="btnDelete" fontSize="24"/>
            <buttons:EditButton addStyleNames="{style.btn}" color="white" ui:field="btnEditor" fontSize="22"/>
        </g:HTMLPanel>
        <g:Image ui:field="image" addStyleNames="{style.img}"/>
        <g:Label ui:field="lbName" addStyleNames="{style.name}"/>
    </g:HTMLPanel>
</ui:UiBinder>