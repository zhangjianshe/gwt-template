<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:widget="urn:import:cn.mapway.ui.client.widget"
             xmlns:tree="urn:import:cn.mapway.ui.client.widget.tree"
             xmlns:buttons="urn:import:cn.mapway.ui.client.widget.buttons">

    <ui:style type="cn.mapway.gwt_template.client.dns.PowerDnsFrame.SStyle">
        /* Layout Panels */
        .westPanel {
            border-right: 1px solid #e2e8f0;
            background-color: #f8fafc;
        }

        .centerPanel {
            padding: 20px;
            background-color: #ffffff;
        }

        /* Header Toolbar */
        .box {
            display: flex;
            align-items: center;
            justify-content: space-between; /* Pushes title to left, button to right */
            padding: 0 15px;
            border-bottom: 1px solid #e2e8f0;
            background-color: #f1f5f9;
        }



        .recordTable {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        /* Added padding directly to the header style.
           If the header lacks padding, the text won't align perfectly
           with the data cells below it.
        */
        .headerStyle {
            background-color: #f8fafc;
            font-weight: 600; /* 600 is slightly cleaner than 'bold' */
            text-align: left;
            color: #475569;
            border-bottom: 2px solid #cbd5e1;
            height: 50px;
        }

        .rowStyle {
            /* In GWT, applying bottom borders to TRs can sometimes fail.
               It is safer to apply them to the cells. */
            transition: background-color 0.15s ease;
        }

        .rowStyle:hover {
            background-color: #f8fafc;
        }

        /* Moved the border-bottom here. Applying it directly to the
           cell guarantees the line renders seamlessly across all columns.
        */
        .cellStyle {
            padding: 12px 10px;
            font-size: 14px;
            color: #334155;
            border-bottom: 1px solid #f1f5f9;
        }

    </ui:style>

    <g:DockLayoutPanel>
        <g:west size="300">
            <g:DockLayoutPanel addStyleNames="{style.westPanel}">
                <g:north size="50">
                    <g:HTMLPanel addStyleNames="{style.box}">
                        <widget:Header >Zone 列表</widget:Header>
                        <g:Button ui:field="btnAddZone">添加ZONE</g:Button>
                    </g:HTMLPanel>
                </g:north>
                <g:center>
                    <g:ScrollPanel>
                        <tree:Tree ui:field="zoneTree" width="100%"/>
                    </g:ScrollPanel>
                </g:center>
            </g:DockLayoutPanel>
        </g:west>
        <g:south size="0">
            <g:HorizontalPanel ui:field="tools">
                <buttons:AiButton ui:field="btnCreateRecord">创建记录</buttons:AiButton>
            </g:HorizontalPanel>
        </g:south>
        <g:center>
            <g:ScrollPanel addStyleNames="{style.centerPanel}">
                <g:FlexTable ui:field="records" addStyleNames="{style.recordTable}">
                </g:FlexTable>
            </g:ScrollPanel>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>