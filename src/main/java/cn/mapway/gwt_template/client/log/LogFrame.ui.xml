<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:widget="urn:import:cn.mapway.ui.client.widget"
             xmlns:buttons="urn:import:cn.mapway.ui.client.widget.buttons">
    <g:DockLayoutPanel>
        <g:north size="80">
            <g:HTMLPanel addStyleNames="ai-flex-panel">
                <g:HorizontalPanel spacing="4" height="80px" verticalAlignment="middle">
                    <widget:SearchBox ui:field="searchBox" width="250px"/>
                    <g:Label width="150px" ui:field="lbTotal"/>
                    <buttons:AiButton ui:field="btnPrev">上一页</buttons:AiButton>
                    <buttons:AiButton ui:field="btnNext">下一页
                    </buttons:AiButton>
                </g:HorizontalPanel>
            </g:HTMLPanel>
        </g:north>
        <g:center>
            <g:FlexTable addStyleNames="attr-table" ui:field="logTable">
            </g:FlexTable>
        </g:center>
    </g:DockLayoutPanel>
</ui:UiBinder>