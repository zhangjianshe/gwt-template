<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        @eval MAIN_COLOR "var(--btn-color-primary)";
        @eval MAIN_COLOR_HOVER "var(--btn-color-primary-hover)";
        .box {
            border-bottom: solid 4px transparent;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 4px;
            border-radius: 8px 8px 0 0;
            gap: 4px;
            height: 50px;
            min-width: 120px;

        }

        .box[select="true"] {
            background-color: MAIN_COLOR;
            border-bottom: solid 4px orange;
        }

        .box:HOVER {
            background-color: MAIN_COLOR_HOVER;
        }

        .name {
            font-size: 1.0rem;
            color: whitesmoke;
        }</ui:style>
    <g:HTMLPanel addStyleNames="{style.box}">
        <widget:FontIcon ui:field="icon" color="white"/>
        <g:Label ui:field="lbName" addStyleNames="{style.name}"/>
    </g:HTMLPanel>
</ui:UiBinder>