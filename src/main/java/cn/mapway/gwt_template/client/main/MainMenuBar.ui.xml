<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        .box {
            display: grid;
            grid-template-columns: 280px 1fr 160px 34px 34px 34px;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 0 10px;
        }

        .btn {
            color: whitesmoke;
            width: 40px;
            height: 40px;
            justify-content: center;
            justify-items: center;
            align-items: center;
            display: flex;
            border-radius: 5px;
        }

        .btn:HOVER {
            background-color: rgba(0, 0, 0, 0.5);
        }

        .exit {
            color: whitesmoke;
            justify-content: center;
            justify-items: center;
            align-items: center;
            display: flex;
            border-radius: 6px;
            gap: 6px;
            padding: 0 15px;
        }

        .exit:hover {
            background-color: rgba(0, 0, 0, 0.5);
        }

        .logo {
            overflow: hidden;
            height: 70px;
        }

        .buttons {
            display: flex;
            align-items: flex-end;
            justify-content: flex-start;
            gap: 1rem;
            height: 100%;
        }</ui:style>
    <g:HTMLPanel styleName="{style.box}">
        <g:Image ui:field="logo" addStyleNames="{style.logo}"/>
        <g:HTMLPanel addStyleNames="{style.buttons}" ui:field="buttons">
        </g:HTMLPanel>
        <g:HTML ui:field="lbUserInfo"/>
        <widget:FontIcon color="skyblue" fontSize="32" addStyleNames="{style.btn}" ui:field="btnIm"/>
        <widget:FontIcon color="skyblue" fontSize="32" addStyleNames="{style.btn}" ui:field="btnPreference"/>
        <widget:FontIcon color="#e0e0e0" fontSize="32" addStyleNames="{style.btn}" ui:field="btnExit"/>
    </g:HTMLPanel>
</ui:UiBinder>